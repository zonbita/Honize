# Server
PORT=4000
SITE_URL=http://localhost:4000
NODE_ENV=development

# Auth
# Generate SESSION_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-32-plus-char-random-secret

# Only this Google account can open /dashboard
ADMIN_EMAIL=zonbita96@gmail.com

# Optional password fallback (omit on Vercel if Google-only)
# ADMIN_PASSWORD=replace-with-strong-password

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI must be exactly:
#   {SITE_URL}/dashboard/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Postgres (Neon / Vercel Postgres / local)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# AI provider: gemini (free) | openai | fallback
AI_PROVIDER=gemini

# Google Gemini — free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# OpenAI — optional fallback (paid / needs billing)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

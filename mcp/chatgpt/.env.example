# Private ChatGPT MCP — local coding only (do not commit secrets)
PORT=3000

# Absolute path to this Honize repo
WORKSPACE_PATH=C:\zzzzzzzzzzzzzzzzzzz\Honize

# Reduce ChatGPT permission popups for coding tools
CHATGPT_AUTO_APPROVE=true
SHELL_TIMEOUT=120
MCP_SESSION_RECOVERY=true

# Keep sandbox on this repo (set true only if you intentionally want full disk)
FULL_DISK_ACCESS=false

# Optional — OpenAI Secure MCP Tunnel (stable URL, private to your org)
# https://platform.openai.com/settings/organization/tunnels
OPENAI_TUNNEL_ID=
OPENAI_TUNNEL_API_KEY=

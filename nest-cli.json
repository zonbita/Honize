{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "../views/**/*", "outDir": "dist/views", "watchAssets": true },
      {
        "include": "../public/**/*",
        "exclude": "../public/uploads/**/*",
        "outDir": "dist/public",
        "watchAssets": true
      },
      { "include": "../content/**/*", "outDir": "dist/content", "watchAssets": true }
    ]
  }
}

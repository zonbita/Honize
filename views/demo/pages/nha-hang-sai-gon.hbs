  <section class="ar-about" id="about">



    <div class="ar-about-inner">



      <div class="ar-about-media" data-aos="fade-right" data-aos-duration="850">



        <img



          src="https://images.unsplash.com/photo-1577219491135-ce391730fb2c?auto=format&fit=crop&w=800&h=600&q=80"



          alt="Đầu bếp Long Nguyễn trong bếp nhà hàng"



          width="560"



          height="420"



        />



      </div>



      <div class="ar-about-copy" data-aos="fade-left" data-aos-delay="110" data-aos-duration="850">



        <p class="ar-about-kicker">Giới thiệu</p>



        <h2 class="ar-about-title">Chef Long Nguyễn</h2>



        <p>



          Sinh ra và lớn lên giữa Sài Gòn, Long Nguyễn bắt đầu nấu ăn từ căn bếp gia đình — nơi ông học cách cân bằng vị chua, cay, mặn, ngọt trong từng món ăn Việt.



        </p>



        <p>



          Sau hơn mười năm làm việc tại các nhà hàng fusion, ông quay về quê hương để mở Aroflit: không gian ẩm thực hiện đại nhưng giữ trọn hồn dân dã — nguyên liệu địa phương, thực đơn theo mùa, và câu chuyện đằng sau mỗi món ăn.



        </p>



        <a href="#reserve" class="ar-btn ar-btn-solid ar-btn-dark">Đặt bàn ngay</a>



      </div>



    </div>



  </section>



  <section class="ar-reserve" id="reserve" aria-label="Đặt bàn">



    <div class="ar-reserve-inner" data-aos="fade-up">



      <div class="ar-reserve-copy">



        <p class="ar-about-kicker">Đặt bàn</p>



        <h2 class="ar-reserve-title">Giữ chỗ cho buổi tối của bạn</h2>



        <p class="ar-reserve-text">Điền thông tin bên dưới — chúng tôi sẽ xác nhận qua điện thoại trong vòng 2 giờ.</p>



      </div>



      <form class="ar-reserve-form" action="#" onsubmit="return false">



        <label class="ar-field">



          <span>Họ tên</span>



          <input type="text" name="name" placeholder="Nguyễn Văn A" required />



        </label>



        <label class="ar-field">



          <span>SĐT</span>



          <input type="tel" name="phone" placeholder="0901 234 567" required />



        </label>



        <label class="ar-field">



          <span>Ngày</span>



          <input type="date" name="date" required />



        </label>



        <label class="ar-field">



          <span>Số khách</span>



          <select name="guests" required>



            <option value="">Chọn số khách</option>



            <option value="2">2 khách</option>



            <option value="3">3 khách</option>



            <option value="4">4 khách</option>



            <option value="5">5 khách</option>



            <option value="6+">6+ khách</option>



          </select>



        </label>



        <button type="submit" class="ar-btn ar-btn-solid ar-btn-wide">Gửi yêu cầu</button>



      </form>



    </div>



  </section>




<script>
  (() => {
    const page = document.querySelector('.nh-page');
    if (!page) return;

    const toggle = page.querySelector('.nh-menu-toggle');
    const nav = page.querySelector('.nh-nav');
    const form = page.querySelector('.nh-form');

    toggle?.addEventListener('click', () => {
      const isOpen = page.classList.toggle('is-menu-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    nav?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        page.classList.remove('is-menu-open');
        toggle?.setAttribute('aria-expanded', 'false');
      });
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      const status = form.querySelector('.nh-form-status');
      if (status) status.textContent = 'Cảm ơn bạn. Kaze sẽ liên hệ xác nhận trong ít phút.';
      form.reset();
    });
  })();
</script>

        <div class="nova-qr" aria-label="QR Code">
          <svg viewBox="0 0 80 80" width="80" height="80" aria-hidden="true">
            <rect width="80" height="80" fill="#fff" rx="4"/>
            <rect x="8" y="8" width="24" height="24" fill="#1a1a1a"/>
            <rect x="48" y="8" width="24" height="24" fill="#1a1a1a"/>
            <rect x="8" y="48" width="24" height="24" fill="#1a1a1a"/>
            <rect x="14" y="14" width="12" height="12" fill="#fff"/>
            <rect x="54" y="14" width="12" height="12" fill="#fff"/>
            <rect x="14" y="54" width="12" height="12" fill="#fff"/>
            <rect x="36" y="36" width="8" height="8" fill="#e31b23"/>

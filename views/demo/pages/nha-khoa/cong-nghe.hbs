<div class="oris-page">
  {{> demo/oris/header }}

  <main>
    <section class="oris-page-hero">
      <div class="oris-page-hero-bg" aria-hidden="true">
        <img src="{{orisHeroBg}}" alt="" width="1600" height="900" />
      </div>
      <div class="oris-page-hero-overlay" aria-hidden="true"></div>
      <div class="oris-wrap oris-page-hero-inner">
        <nav class="oris-breadcrumb" aria-label="Breadcrumb">
          <a href="{{orisBase}}">Trang chủ</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">Công nghệ</span>
        </nav>
        <h1>Công nghệ số</h1>
        <p class="oris-page-hero-text">
          Chẩn đoán chính xác, mô phỏng kết quả trước điều trị — trải nghiệm nha khoa hiện đại tại ORIS.
        </p>
      </div>
    </section>

    <section class="oris-section">
      <div class="oris-wrap oris-split">
        <div data-aos="fade-up">
          <img src="/images/Demo/NhaKhoa/08-tech-digital.png" alt="Máy quét intraoral 3D" width="900" height="675" loading="lazy" />
        </div>
        <div data-aos="fade-up" data-aos-delay="80">
          <p class="oris-label">Intraoral scan</p>
          <h2>Quét 3D thay thế lấy dấu truyền thống</h2>
          <p style="margin-top:16px;color:var(--oris-text-secondary)">
            Máy quét trong miệng cho hình ảnh chi tiết tức thì, giảm khó chịu và tăng độ chính xác cho phục hình, chỉnh nha và implant.
          </p>
          <ul class="oris-checklist">
            <li>Hình ảnh độ phân giải cao</li>
            <li>Thời gian thăm khám ngắn hơn</li>
            <li>Lưu trữ hồ sơ số hóa</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="oris-section" style="padding-top:0;background:var(--oris-bg-soft)">
      <div class="oris-wrap" style="padding-top:72px;padding-bottom:72px">
        <div class="oris-section-head" data-aos="fade-up">
          <p class="oris-label">Ứng dụng lâm sàng</p>
          <h2>Công nghệ phục vụ điều trị</h2>
        </div>
        <div class="oris-values" data-aos="fade-up">
          <article class="oris-value">
            <h3>Mô phỏng nụ cười</h3>
            <p>Xem trước kết quả thẩm mỹ trên ảnh khuôn mặt trước khi bắt đầu liệu trình.</p>
          </article>
          <article class="oris-value">
            <h3>Kế hoạch chỉnh nha số</h3>
            <p>Từng bước di chuyển răng được tính toán và hiển thị rõ ràng cho khách hàng.</p>
          </article>
          <article class="oris-value">
            <h3>Hướng dẫn phẫu thuật</h3>
            <p>Mẫu dẫn đường implant giúp đặt trụ chính xác theo kế hoạch đã thống nhất.</p>
          </article>
        </div>
        <div style="margin-top:40px;text-align:center" data-aos="fade-up">
          <img class="oris-float" src="/images/Demo/NhaKhoa/10-3d-tooth.png" alt="" width="200" height="200" loading="lazy" style="width:180px;height:auto" />
        </div>
      </div>
    </section>
  </main>

  {{> demo/oris/footer }}
</div>

{{> demo/oris/scripts }}

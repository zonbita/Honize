<div class="tmv-page tmv-page--home">
  {{> demo/tmv/header }}

  <section class="tmv-hero" id="home">
    <div class="tmv-hero-bg" aria-hidden="true">
      <img src="/images/ThamMyVien/thammyvien%20(4).png" alt="" width="1600" height="900" />
      <div class="tmv-hero-overlay"></div>
    </div>

    <div class="tmv-container tmv-hero-inner">
      <div class="tmv-hero-content" data-aos="fade-up" data-aos-duration="600">
        <p class="tmv-label">CHĂM SÓC DA CHUYÊN SÂU</p>
        <h1 class="tmv-hero-title">
          Làn da khỏe đẹp<br />
          từ sự tinh tế<br />
          &amp; <em>thấu hiểu</em>
        </h1>
        <p class="tmv-hero-text">
          Cá nhân hóa giải pháp chăm sóc da chuẩn y khoa — an toàn, tinh tế và hướng đến hiệu quả bền vững.
        </p>
        <div class="tmv-hero-actions">
          <a href="#booking" class="tmv-btn tmv-btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18" aria-hidden="true">
              <rect x="3" y="5" width="18" height="16" rx="2"/>
              <path d="M3 10h18M8 3v4M16 3v4"/>
            </svg>
            Đặt lịch tư vấn
          </a>
          <a href="{{tmvBase}}/dich-vu" class="tmv-btn tmv-btn-text">
            <span class="tmv-play" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" width="10" height="10"><path d="M8 5v14l11-7z"/></svg>
            </span>
            Khám phá dịch vụ
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="tmv-metrics" aria-label="Số liệu tin cậy" data-aos="fade-up" data-aos-duration="600">
    <div class="tmv-metrics-panel">
      <article class="tmv-metric">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
        </svg>
        <strong><span class="tmv-count" data-count="15000" data-separator="." data-suffix="+">0</span></strong>
        <span>Khách hàng tin tưởng</span>
      </article>
      <article class="tmv-metric">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7L12 16.8 5.7 21l2.3-7-6-4.6h7.6z"/>
        </svg>
        <strong><span class="tmv-count" data-count="98" data-suffix="%">0</span></strong>
        <span>Khách hàng hài lòng</span>
      </article>
      <article class="tmv-metric">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <strong><span class="tmv-count" data-count="100" data-suffix="%">0</span></strong>
        <span>Quy trình an toàn</span>
      </article>
      <article class="tmv-metric">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="12" cy="12" r="9"/>
          <path d="M12 7v5l3 2"/>
        </svg>
        <strong><span class="tmv-count" data-count="8" data-suffix="+ năm">0</span></strong>
        <span>Kinh nghiệm chuyên môn</span>
      </article>
    </div>
  </section>

  <section class="tmv-section tmv-services" id="services">
    <div class="tmv-container">
      <div class="tmv-section-head" data-aos="fade-up" data-aos-duration="600">
        <p class="tmv-label">DỊCH VỤ NỔI BẬT</p>
        <h2>Chăm sóc làn da theo cách riêng của bạn</h2>
        <span class="tmv-heading-line" aria-hidden="true"></span>
      </div>

      <div class="tmv-services-grid">
        <article class="tmv-service-card" data-aos="fade-up" data-aos-duration="600">
          <div class="tmv-service-media">
            <img src="/images/ThamMyVien/thammyvien%20(4).png" alt="Chăm sóc da cá nhân hóa" loading="lazy" width="400" height="270" />
          </div>
          <div class="tmv-service-body">
            <h3>Chăm sóc da cá nhân hóa</h3>
            <p>Phác đồ điều trị được thiết kế riêng theo tình trạng da và mục tiêu của từng khách hàng.</p>
            <a href="#booking" class="tmv-link">Tìm hiểu thêm <span aria-hidden="true">→</span></a>
          </div>
        </article>

        <article class="tmv-service-card" data-aos="fade-up" data-aos-delay="80" data-aos-duration="600">
          <div class="tmv-service-media">
            <img src="/images/ThamMyVien/thammyvien%20(1).png" alt="Trẻ hóa và phục hồi da" loading="lazy" width="400" height="270" />
          </div>
          <div class="tmv-service-body">
            <h3>Trẻ hóa &amp; phục hồi</h3>
            <p>Công nghệ hiện đại giúp phục hồi cấu trúc da, cải thiện độ săn chắc và độ đàn hồi.</p>
            <a href="#booking" class="tmv-link">Tìm hiểu thêm <span aria-hidden="true">→</span></a>
          </div>
        </article>

        <article class="tmv-service-card" data-aos="fade-up" data-aos-delay="160" data-aos-duration="600">
          <div class="tmv-service-media">
            <img src="/images/ThamMyVien/thammyvien%20(5).png" alt="Dưỡng sáng và đều màu da" loading="lazy" width="400" height="270" />
          </div>
          <div class="tmv-service-body">
            <h3>Dưỡng sáng &amp; đều màu da</h3>
            <p>Giải pháp làm sáng an toàn, giảm thâm nám và mang lại làn da đều màu, rạng rỡ.</p>
            <a href="#booking" class="tmv-link">Tìm hiểu thêm <span aria-hidden="true">→</span></a>
          </div>
        </article>

        <article class="tmv-service-card" data-aos="fade-up" data-aos-delay="240" data-aos-duration="600">
          <div class="tmv-service-media">
            <img
              src="https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?auto=format&fit=crop&w=800&q=80"
              alt="Cấp ẩm và cân bằng da"
              loading="lazy"
              width="400"
              height="270"
            />
          </div>
          <div class="tmv-service-body">
            <h3>Cấp ẩm &amp; cân bằng da</h3>
            <p>Bổ sung độ ẩm sâu, phục hồi hàng rào bảo vệ da và giữ làn da mềm mịn suốt ngày dài.</p>
            <a href="#booking" class="tmv-link">Tìm hiểu thêm <span aria-hidden="true">→</span></a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="tmv-tech" id="technology">
    <div class="tmv-tech-grid">
      <div class="tmv-tech-content" data-aos="fade-up" data-aos-duration="600">
        <div class="tmv-tech-content-inner">
          <p class="tmv-label">CÔNG NGHỆ &amp; TIÊU CHUẨN</p>
          <h2>Công nghệ hiện đại<br />Chuẩn mực an toàn</h2>
          <p class="tmv-tech-text">
            Ứng dụng công nghệ tiên tiến kết hợp cùng quy trình chuẩn hóa, mang đến trải nghiệm chăm sóc tối ưu trong không gian tinh tế.
          </p>
          <ul class="tmv-tech-list">
            <li>
              <span class="tmv-tech-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/></svg>
              </span>
              <div class="tmv-tech-list-text">
                <strong>Công nghệ tiên tiến</strong>
                <span>Được chọn lọc và kiểm chứng</span>
              </div>
            </li>
            <li>
              <span class="tmv-tech-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
              </span>
              <div class="tmv-tech-list-text">
                <strong>Quy trình chuẩn y khoa</strong>
                <span>An toàn – Tinh tế – Hiệu quả</span>
              </div>
            </li>
            <li>
              <span class="tmv-tech-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>
              </span>
              <div class="tmv-tech-list-text">
                <strong>Sản phẩm cao cấp</strong>
                <span>Lành tính và hiệu quả</span>
              </div>
            </li>
          </ul>
          <a href="#booking" class="tmv-btn tmv-btn-primary">Khám phá công nghệ</a>
        </div>
      </div>
      <div class="tmv-tech-media" data-aos="fade-up" data-aos-delay="80" data-aos-duration="600">
        <img
          src="/images/ThamMyVien/thammyvien%20(1).png"
          alt="Phòng điều trị hiện đại với thiết bị chăm sóc da chuẩn y khoa"
          loading="lazy"
          width="900"
          height="700"
        />
      </div>
    </div>
  </section>

  <section class="tmv-section tmv-journey" id="about">
    <div class="tmv-container">
      <div class="tmv-section-head" data-aos="fade-up" data-aos-duration="600">
        <p class="tmv-label">HÀNH TRÌNH TRẢI NGHIỆM</p>
        <h2>5 bước cho làn da khỏe đẹp bền vững</h2>
        <span class="tmv-heading-line" aria-hidden="true"></span>
      </div>

      <div class="tmv-journey-track" data-aos="fade-up" data-aos-duration="600">
        {{> demo/tmv/journey-steps }}
      </div>
    </div>
  </section>

  <section class="tmv-section tmv-testimonials" id="knowledge">
    <div class="tmv-testimonials-deco tmv-testimonials-deco--left" aria-hidden="true">
      <img src="/images/ThamMyVien/thammyvien%20(3).png" alt="" />
    </div>
    <div class="tmv-testimonials-deco tmv-testimonials-deco--right" aria-hidden="true">
      <img src="/images/ThamMyVien/thammyvien%20(3).png" alt="" />
    </div>

    <div class="tmv-container">
      <div class="tmv-section-head" data-aos="fade-up" data-aos-duration="600">
        <p class="tmv-label">KHÁCH HÀNG NÓI GÌ VỀ CHÚNG TÔI</p>
        <h2>Khách hàng nói gì về chúng tôi</h2>
        <span class="tmv-heading-line" aria-hidden="true"></span>
      </div>

      <div class="tmv-testimonials-grid" data-aos="fade-up" data-aos-duration="600">
        <article class="tmv-quote-card">
          <span class="tmv-quote-mark" aria-hidden="true">“</span>
          <p>Làn da mình cải thiện rõ rệt sau 4 buổi. Không gian tinh tế, bác sĩ tư vấn rất tận tâm và chuyên nghiệp.</p>
          <footer>
            <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=120&h=120&q=80" alt="" width="44" height="44" />
            <div>
              <strong>Nguyễn Hoài An</strong>
              <span>Khách hàng</span>
            </div>
          </footer>
        </article>
        <article class="tmv-quote-card">
          <span class="tmv-quote-mark" aria-hidden="true">“</span>
          <p>Mình thích cách họ cá nhân hóa phác đồ. Kết quả đều màu da vượt kỳ vọng, cảm giác rất an toàn khi điều trị.</p>
          <footer>
            <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&w=120&h=120&q=80" alt="" width="44" height="44" />
            <div>
              <strong>Lê Minh Châu</strong>
              <span>Khách hàng</span>
            </div>
          </footer>
        </article>
        <article class="tmv-quote-card">
          <span class="tmv-quote-mark" aria-hidden="true">“</span>
          <p>Từ khâu thăm khám đến hướng dẫn chăm sóc tại nhà đều chu đáo. Đây là nơi mình tin tưởng gửi gắm làn da.</p>
          <footer>
            <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=120&h=120&q=80" alt="" width="44" height="44" />
            <div>
              <strong>Trần Thu Thảo</strong>
              <span>Khách hàng</span>
            </div>
          </footer>
        </article>
      </div>

      <div class="tmv-dots" role="tablist" aria-label="Đánh giá khách hàng">
        <button type="button" class="is-active" aria-label="Nhóm đánh giá 1" aria-selected="true"></button>
        <button type="button" aria-label="Nhóm đánh giá 2" aria-selected="false"></button>
        <button type="button" aria-label="Nhóm đánh giá 3" aria-selected="false"></button>
      </div>
    </div>
  </section>

  <section class="tmv-section tmv-booking-wrap" id="booking">
    <div class="tmv-booking-bg" aria-hidden="true">
      <img src="/images/ThamMyVien/thammyvien%20(3).png" alt="" width="1920" height="1080" />
    </div>
    <div class="tmv-container tmv-booking" data-aos="fade-up" data-aos-duration="600">
      <div class="tmv-booking-content">
        <h2>Đặt lịch tư vấn</h2>
        <p class="tmv-booking-sub">Trải nghiệm cá nhân hóa dành riêng cho bạn</p>
        <ul class="tmv-checklist">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true"><path d="M5 13l4 4L19 7"/></svg>
            Thăm khám chuyên sâu
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true"><path d="M5 13l4 4L19 7"/></svg>
            Tư vấn giải pháp phù hợp
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true"><path d="M5 13l4 4L19 7"/></svg>
            Trải nghiệm không gian chuẩn 5 sao
          </li>
        </ul>
        <div class="tmv-booking-actions">
          <a href="tel:19001234" class="tmv-btn tmv-btn-primary">Đặt lịch ngay</a>
          <div class="tmv-booking-phone">
            <a href="tel:19001234">1900 1234</a>
            <span>08:30 – 20:00 | T2 – CN</span>
          </div>
        </div>
      </div>
      <div class="tmv-booking-visual">
        <img
          src="/images/ThamMyVien/thammyvien%20(5).png"
          alt="Bộ sản phẩm serum cao cấp của Aesthetic Clinic"
          loading="lazy"
          width="520"
          height="420"
        />
      </div>
    </div>
  </section>

  {{> demo/tmv/footer }}
</div>

{{> demo/tmv/scripts }}

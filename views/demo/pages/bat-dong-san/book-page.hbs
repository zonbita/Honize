<div class="gb-page gb-coded-page gb-coded-page--{{gbBookPageKey}}">
  <section class="gb-poster" aria-label="{{gbBookAlt}}">
    <div class="gb-silk" aria-hidden="true"></div>

    <div class="gb-stage gb-coded-canvas">
      <header class="gb-brand">
        <a href="/du-an/demo/bat-dong-san" class="gb-logo" aria-label="Green Building — Trang chủ">
          <svg class="gb-logo-mark" viewBox="0 0 48 56" fill="none" aria-hidden="true">
            <rect x="1.5" y="1.5" width="45" height="53" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 48V24M19 48V14M24 48V8M29 48V16M36 48V28" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
          </svg>
          <span class="gb-logo-text">GREEN BUILDING</span>
        </a>
      </header>

    <div class="gb-book-content gb-book-turn-target">
    {{#if (eq gbBookPageKey "investment")}}
      <div class="gb-invest-hero">
        <div class="gb-invest-stats">
          <p><strong>6,1</strong><span>Tỷ / căn</span></p>
          <small>CHIẾT KHẤU TỚI</small>
          <p><strong>9</strong><b>%</b></p>
        </div>
        <img src="/images/Demo/House/house%20(3).m.webp" alt="Toàn cảnh khu đô thị Green Building" />
        <div class="gb-invest-title">
          <em>Tâm điểm</em>
          <h1>GIAO THƯƠNG<br />ĐẦU TƯ THỊNH VƯỢNG</h1>
        </div>
      </div>

      <div class="gb-invest-grid">
        <article>
          <img src="/images/Demo/House/house%20(2).m.webp" alt="Trung tâm thương mại" />
          <h2>TRUNG TÂM<br />THƯƠNG MẠI</h2>
        </article>
        <article>
          <img src="/images/Demo/House/house%20(3).m.webp" alt="Công viên trung tâm" />
          <h2>CÔNG VIÊN</h2>
        </article>
        <article>
          <img src="/images/Demo/House/house%20(4).m.webp" alt="Nhà văn hóa" />
          <h2>NHÀ VĂN HÓA</h2>
        </article>
        <article>
          <img src="/images/Demo/BatDongSan/01-towers-exterior.png" alt="Trường học nội khu" />
          <h2>TRƯỜNG HỌC<br />NỘI KHU</h2>
        </article>
        <div class="gb-rate">
          <strong>0<sup>%</sup></strong>
          <span>LÃI SUẤT</span>
          <em>Trong</em>
          <b>24</b>
          <span>THÁNG</span>
        </div>
      </div>
    {{/if}}

    {{#if (eq gbBookPageKey "star-district")}}
      <div class="gb-star-hero">
        <div class="gb-star-heading">
          <p>KHU</p>
          <h1>ÁNH SAO</h1>
          <span>CỬA NGÕ MUA SẮM · GIẢI TRÍ</span>
          <em>Sôi động</em>
        </div>
        <img src="/images/Demo/BatDongSan/01-towers-exterior.png" alt="Phố thương mại Khu Ánh Sao" />
        <ul class="gb-star-facts">
          <li>Tối đa công năng với <strong>4 tầng</strong></li>
          <li>Diện tích sử dụng lên đến <strong>192,9–579,1 m²</strong></li>
          <li>Long đường rộng <strong>15–30 m</strong></li>
        </ul>
      </div>

      <div class="gb-star-metrics">
        <p><span>QUẢNG TRƯỜNG GOLDEN GATE</span><strong>20.773 m²</strong></p>
        <p><span>MUA SẮM TRỊ LIỆU</span><strong>120.000 m²</strong></p>
        <p><span>CÔNG VIÊN WATERFALL PARK</span><strong>12.759 m²</strong></p>
        <p><span>TỔ HỢP VUI CHƠI</span><strong>18.027 m²</strong></p>
      </div>

      <div class="gb-star-bottom">
        <article class="gb-star-specs">
          <h2>CẤU THÀNH SẢN PHẨM</h2>
          <p>DIỆN TÍCH TỔNG<strong>53,4 ha</strong></p>
          <p>BIỆT THỰ ĐƠN LẬP<strong>30 căn</strong></p>
          <p>NHÀ LIÊN KẾ<strong>640 căn</strong></p>
        </article>
        <article class="gb-star-parks">
          <h2><strong>3</strong> CÔNG VIÊN<br />NỘI KHU</h2>
          <span>TỔNG DIỆN TÍCH LÊN TỚI <b>15.281 m²</b></span>
          <div>
            <img src="/images/Demo/House/house%20(3).m.webp" alt="Công viên nội khu thứ nhất" />
            <img src="/images/Demo/House/house%20(5).m.webp" alt="Công viên nội khu thứ hai" />
          </div>
        </article>
      </div>
    {{/if}}

    {{#if (eq gbBookPageKey "tourism")}}
      <div class="gb-tourism-heading">
        <strong>3</strong>
        <div>
          <em>Yếu tố</em>
          <h1><span>GREEN</span> giúp <b>BUILDING</b></h1>
          <p>THĂNG HẠNG TRÊN BẢN ĐỒ DU LỊCH</p>
        </div>
      </div>

      <div class="gb-tourism-resort">
        <img src="/images/Demo/House/house%20(5).m.webp" alt="Khu nghỉ dưỡng bên biển" />
        <span class="gb-tourism-coast" aria-hidden="true"></span>
      </div>

      <div class="gb-brochure">
        <article>
          <em>Sân bay</em>
          <h2>LONG THÀNH</h2>
          <p>Kết nối quốc tế</p>
          <img src="/images/Demo/House/house%20(3).m.webp" alt="Hạ tầng kết nối" />
        </article>
        <article>
          <em>Resort</em>
          <h2>5 SAO ĐẦU TIÊN</h2>
          <p>Sắp bàn giao</p>
          <img src="/images/Demo/House/house%20(2).m.webp" alt="Resort năm sao" />
        </article>
        <article>
          <em>Nguồn lực</em>
          <h2>TỪ ĐẠI DỰ ÁN</h2>
          <p>Vươn xa</p>
          <img src="/images/Demo/House/house%20(5).m.webp" alt="Du lịch biển" />
        </article>
      </div>
      <span class="gb-hand gb-hand--left" aria-hidden="true"></span>
      <span class="gb-hand gb-hand--right" aria-hidden="true"></span>
    {{/if}}

    {{#if (eq gbBookPageKey "golf")}}
      <div class="gb-golf-title">
        <span>1</span>
        <em>chuẩn sống</em>
        <strong>2 SÂN GOLF<br />THƯỢNG LƯU</strong>
      </div>
      <div class="gb-golf-gallery">
        <img src="/images/Demo/House/house%20(2).m.webp" alt="Biệt thự sân golf" />
        <img src="/images/Demo/House/house%20(6).m.webp" alt="Biệt thự thượng lưu" />
        <img src="/images/Demo/House/house%20(3).m.webp" alt="Cảnh quan sân golf" />
      </div>
      <div class="gb-golf-club" aria-hidden="true">
        <span class="gb-golf-green"><i></i></span>
        <span class="gb-golf-ball"></span>
        <span class="gb-golf-shaft"></span>
      </div>
    {{/if}}

    {{#if (eq gbBookPageKey "attraction")}}
      <div class="gb-attract-top">
        <div class="gb-attract-number">3</div>
        <div class="gb-attract-title">
          <em>Yếu tố</em>
          <h1>TẠO SỨC HÚT<br />BỀN BỈ</h1>
          <p>cho Green Building</p>
        </div>
        <img src="/images/Demo/BatDongSan/01-towers-exterior.png" alt="Khu đô thị Green Building" />
      </div>

      <div class="gb-attract-feature gb-attract-feature--right">
        <div>
          <em>Tọa độ</em>
          <h2>CHIẾN LƯỢC</h2>
          <p>Dòng khách bền vững</p>
        </div>
        <img src="/images/Demo/House/house%20(3).m.webp" alt="Vị trí chiến lược" />
      </div>

      <div class="gb-attract-feature gb-attract-feature--left">
        <div>
          <em>Quy hoạch</em>
          <h2>BÀI BẢN</h2>
          <p>Sản phẩm linh hoạt</p>
        </div>
        <img src="/images/Demo/House/house%20(6).m.webp" alt="Quy hoạch đồng bộ" />
      </div>

      <div class="gb-attract-feature gb-attract-feature--right gb-attract-feature--last">
        <div>
          <em>Tiềm năng</em>
          <h2>ĐẦU TƯ DÀI HẠN</h2>
          <p>Hạ tầng, quy hoạch cộng hưởng</p>
        </div>
        <img src="/images/Demo/House/house%20(2).m.webp" alt="Tiềm năng đầu tư dài hạn" />
      </div>
      {{/if}}
    </div>
    </div>

    {{> demo/green-building-book-nav
      prevHref=gbBookPrevHref
      nextHref=gbBookNextHref
      pageNumber=gbBookPageNumber
      pageTotal=gbBookTotal
    }}
  </section>

  {{> demo/green-building-common-sections }}
</div>

<div class="gb-page gb-coded-page gb-coded-page--{{gbBookPageKey}}">
  <section class="gb-poster" aria-label="{{gbBookAlt}}">
    <div class="gb-silk" aria-hidden="true"></div>

    <div class="gb-stage gb-coded-canvas">
      <header class="gb-brand">
        <a href="/du-an/demo/bat-dong-san" class="gb-logo" aria-label="Green Building — Trang chủ">
          <svg class="gb-logo-mark" viewBox="0 0 48 56" fill="none" aria-hidden="true">
            <rect x="1.5" y="1.5" width="45" height="53" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 48V24M19 48V14M24 48V8M29 48V16M36 48V28" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
          </svg>
          <span class="gb-logo-text">GREEN BUILDING</span>
        </a>
      </header>

    <div class="gb-book-content gb-book-turn-target">
    {{#if (eq gbBookPageKey "investment")}}
      <div class="gb-invest-hero">
        <div class="gb-invest-stats">
          <p><strong>6,1</strong><span>Tỷ / căn</span></p>
          <small>CHIẾT KHẤU TỚI</small>
          <p><strong>9</strong><b>%</b></p>
        </div>
        <div class="gb-invest-visual">
          <img src="/images/Demo/BatDongSan/dau-tu/hero-aerial.png" alt="Toàn cảnh khu đô thị Green Building" width="1600" height="900" />
          <span class="gb-invest-glow" aria-hidden="true"></span>
          <span class="gb-invest-sparkles" aria-hidden="true"></span>
        </div>
        <div class="gb-invest-title">
          <em>Tâm điểm</em>
          <h1>GIAO THƯƠNG<br />ĐẦU TƯ THỊNH VƯỢNG</h1>
        </div>
      </div>

      <div class="gb-invest-grid">
        <article>
          <img src="/images/Demo/BatDongSan/dau-tu/mall.png" alt="Trung tâm thương mại" width="800" height="800" />
          <h2>TRUNG TÂM<br />THƯƠNG MẠI</h2>
        </article>
        <article>
          <img src="/images/Demo/BatDongSan/dau-tu/park.png" alt="Công viên trung tâm" width="800" height="800" />
          <h2>CÔNG VIÊN</h2>
        </article>
        <article>
          <img src="/images/Demo/BatDongSan/dau-tu/cultural.png" alt="Nhà văn hóa" width="800" height="800" />
          <h2>NHÀ VĂN HÓA</h2>
        </article>
        <article>
          <img src="/images/Demo/BatDongSan/dau-tu/school.png" alt="Trường học nội khu" width="800" height="800" />
          <h2>TRƯỜNG HỌC<br />NỘI KHU</h2>
        </article>
        <div class="gb-rate">
          <strong>0<sup>%</sup></strong>
          <span>LÃI SUẤT</span>
          <em>Trong</em>
          <b>24</b>
          <span>THÁNG</span>
        </div>
      </div>
    {{/if}}

    {{#if (eq gbBookPageKey "star-district")}}
      <div class="gb-star-board">
        <div class="gb-star-hero">
          <div class="gb-star-visual">
            <img
              src="/images/Demo/BatDongSan/anh-sao/street.png"
              alt="Phố thương mại Khu Ánh Sao"
              width="1600"
              height="900"
            />
            <div class="gb-star-visual-shade" aria-hidden="true"></div>

            <div class="gb-star-heading">
              <p>KHU</p>
              <h1>ÁNH SAO</h1>
              <span>CỬA NGÕ MUA SẮM GIẢI TRÍ</span>
              <em>Sôi động</em>
            </div>

            <ul class="gb-star-facts">
              <li>Tối đa công năng với <strong>4&nbsp;tầng</strong></li>
              <li>Diện tích sử dụng lớn <strong>192,9&nbsp;–&nbsp;579,1&nbsp;m²</strong></li>
              <li>Lòng đường rộng <strong>15&nbsp;–&nbsp;30&nbsp;m</strong></li>
            </ul>
          </div>
        </div>

        <div class="gb-star-metrics">
          <p>
            <span>QUẢNG TRƯỜNG<br />GOLDEN GATE</span>
            <strong>20.773&nbsp;m²</strong>
          </p>
          <p>
            <span>MUA SẮM TRỊ LIỆU<br />THERAPY SHOPPING PARK</span>
            <strong>120.000&nbsp;m²</strong>
          </p>
          <p>
            <span>CÔNG VIÊN<br />WATERFALL PARK</span>
            <strong>12.759&nbsp;m²</strong>
          </p>
          <p>
            <span>TỔ HỢP VUI CHƠI GIẢI TRÍ<br />ADVENTURE PARK</span>
            <strong>18.027&nbsp;m²</strong>
          </p>
        </div>

        <div class="gb-star-bottom">
          <article class="gb-star-specs">
            <h2>CẤU THÀNH SẢN PHẨM</h2>
            <p><span>DIỆN TÍCH TỔNG</span><strong>53,4&nbsp;ha</strong></p>
            <p><span>BIỆT THỰ ĐƠN LẬP</span><strong>30&nbsp;căn</strong></p>
            <p><span>NHÀ LIỀN KỀ</span><strong>640&nbsp;căn</strong></p>
          </article>

          <article class="gb-star-parks">
            <div class="gb-star-parks-head">
              <h2><strong>3</strong> CÔNG VIÊN NỘI KHU</h2>
              <span>TỔNG DIỆN TÍCH LÊN TỚI <b>15.281&nbsp;m²</b></span>
            </div>
            <div class="gb-star-parks-media">
              <img src="/images/Demo/BatDongSan/anh-sao/park-1.png" alt="Công viên glamping nội khu" width="800" height="450" />
              <img src="/images/Demo/BatDongSan/anh-sao/park-2.png" alt="Công viên cảnh quan nội khu" width="800" height="450" />
            </div>
          </article>
        </div>
      </div>
    {{/if}}

    {{#if (eq gbBookPageKey "tourism")}}
      <div class="gb-tourism-board">
        <div class="gb-tourism-heading">
          <strong>3</strong>
          <div>
            <em>Yếu tố</em>
            <h1><span>GREEN</span> giúp <b>BUILDING</b></h1>
            <p>THĂNG HẠNG TRÊN BẢN ĐỒ DU LỊCH</p>
          </div>
        </div>

        <div class="gb-tourism-stage">
          <div class="gb-tourism-resort">
            <img
              src="/images/Demo/BatDongSan/du-lich/resort.png"
              alt="Khu nghỉ dưỡng ven biển Green Building"
              width="1600"
              height="900"
            />
            <span class="gb-tourism-coast" aria-hidden="true"></span>
          </div>

          <div class="gb-brochure-wrap">
            <div class="gb-brochure">
              <article>
                <em>Sân bay</em>
                <h2>LONG THÀNH<br />&amp; HỆ THỐNG CAO TỐC</h2>
                <img src="/images/Demo/BatDongSan/du-lich/airport.png" alt="Sân bay Long Thành" width="800" height="600" />
              </article>
              <article>
                <em>Resort</em>
                <h2>5 SAO ĐẦU TIÊN<br />SẮP BÀN GIAO</h2>
                <img src="/images/Demo/BatDongSan/du-lich/balcony.png" alt="Resort 5 sao sắp bàn giao" width="800" height="600" />
              </article>
              <article>
                <h2>NGUỒN LỰC TỪ DI SẢN</h2>
                <em>Văn hóa</em>
                <img src="/images/Demo/BatDongSan/du-lich/coast.png" alt="Di sản văn hóa và biển" width="800" height="600" />
              </article>
            </div>

            <span class="gb-hand gb-hand--left" aria-hidden="true">
              <i class="gb-finger"></i>
              <i class="gb-finger"></i>
              <i class="gb-finger"></i>
              <i class="gb-finger"></i>
            </span>
            <span class="gb-hand gb-hand--right" aria-hidden="true">
              <i class="gb-finger"></i>
              <i class="gb-finger"></i>
              <i class="gb-finger"></i>
              <i class="gb-finger"></i>
            </span>
          </div>
        </div>
      </div>
    {{/if}}

    {{#if (eq gbBookPageKey "golf")}}
      <div class="gb-golf-board">
        <div class="gb-golf-title">
          <h1>2 SÂN GOLF</h1>
          <p>
            <span>1</span>
            <em>chuẩn sống</em>
            <strong>THƯỢNG LƯU</strong>
          </p>
        </div>

        <div class="gb-golf-stage">
          <img
            class="gb-golf-aerial"
            src="/images/Demo/BatDongSan/san-golf/aerial-faint.png"
            alt=""
            aria-hidden="true"
            width="1600"
            height="900"
          />

          <div class="gb-golf-gallery">
            <figure class="gb-golf-panel gb-golf-panel--left">
              <img
                src="/images/Demo/BatDongSan/san-golf/villa-left.png"
                alt="Biệt thự hiện đại ven sân golf"
                width="900"
                height="1200"
              />
            </figure>
            <figure class="gb-golf-panel gb-golf-panel--center">
              <img
                src="/images/Demo/BatDongSan/san-golf/villa-center.png"
                alt="Biệt thự thượng lưu Green Building"
                width="900"
                height="1200"
              />
            </figure>
            <figure class="gb-golf-panel gb-golf-panel--right">
              <img
                src="/images/Demo/BatDongSan/san-golf/villa-right.png"
                alt="Không gian sống thượng lưu"
                width="900"
                height="1200"
              />
            </figure>
          </div>

          <div class="gb-golf-club">
            <img
              src="/images/Demo/BatDongSan/san-golf/golf-club.png"
              alt="Gậy golf với sân putting thu nhỏ"
              width="1600"
              height="900"
            />
            <span class="gb-golf-glow" aria-hidden="true"></span>
          </div>
        </div>
      </div>
    {{/if}}

    {{#if (eq gbBookPageKey "attraction")}}
      <div class="gb-attract-board">
        <div class="gb-attract-waves" aria-hidden="true">
          <svg viewBox="0 0 1200 900" preserveAspectRatio="none">
            <path d="M-40 220 C180 160 320 300 520 250 S860 140 1240 210" />
            <path d="M-40 290 C220 230 380 360 560 310 S900 200 1240 280" />
            <path d="M-40 470 C200 410 360 560 580 500 S920 390 1240 470" />
            <path d="M-40 540 C240 480 400 620 600 560 S940 450 1240 540" />
            <path d="M-40 700 C210 640 370 790 590 730 S930 620 1240 710" />
            <path d="M-40 770 C250 710 410 860 620 800 S960 690 1240 780" />
          </svg>
        </div>

        <header class="gb-attract-hero">
          <div class="gb-attract-number" aria-hidden="true">3</div>
          <div class="gb-attract-title">
            <em>Yếu tố</em>
            <h1>TẠO SỨC HÚT<br />BỀN BỈ <span>cho</span></h1>
            <p>Green Building</p>
          </div>
        </header>

        <article class="gb-attract-row gb-attract-row--strategy">
          <figure class="gb-attract-media">
            <img
              src="/images/Demo/BatDongSan/suc-hut/toa-do.png"
              alt="Dãy nhà phố hiện đại — tọa độ chiến lược"
              width="1600"
              height="900"
            />
          </figure>
          <div class="gb-attract-copy">
            <em>Tọa độ</em>
            <h2>CHIẾN LƯỢC</h2>
            <p>Dòng khách bền vững</p>
          </div>
        </article>

        <article class="gb-attract-row gb-attract-row--plan">
          <div class="gb-attract-copy">
            <em>Quy hoạch</em>
            <h2>BÀI BẢN</h2>
            <p>Sản phẩm linh hoạt</p>
          </div>
          <figure class="gb-attract-media gb-attract-media--soft">
            <img
              src="/images/Demo/BatDongSan/suc-hut/quy-hoach.png"
              alt="Quy hoạch đồng bộ Green Building"
              width="1600"
              height="900"
            />
          </figure>
        </article>

        <article class="gb-attract-row gb-attract-row--invest">
          <figure class="gb-attract-oval">
            <img
              src="/images/Demo/BatDongSan/suc-hut/tiem-nang.png"
              alt="Không gian đầu tư dài hạn với biểu tượng la bàn vàng"
              width="1600"
              height="900"
            />
            <span class="gb-attract-oval-glow" aria-hidden="true"></span>
          </figure>
          <div class="gb-attract-copy">
            <em>Tiềm năng</em>
            <h2>ĐẦU TƯ DÀI HẠN</h2>
            <p>Hạ tầng, quy hoạch cộng hưởng</p>
          </div>
        </article>
      </div>
    {{/if}}
    </div>
    </div>

    {{> demo/green-building-book-nav
      prevHref=gbBookPrevHref
      nextHref=gbBookNextHref
      pageNumber=gbBookPageNumber
      pageTotal=gbBookTotal
    }}
  </section>

  {{> demo/green-building-common-sections }}
</div>

{{> demo/toolbar }}



<div class="lc-page">

  <section class="lc-hero-wrap">

    <header class="lc-header">

      <div class="lc-wrap lc-header-inner">

        <a href="/du-an/demo/corporate-landing" class="lc-logo">

          <span class="lc-logo-mark">LaCasa</span>

          <span class="lc-logo-sub">tổ ấm ngọt ngào</span>

        </a>



        <nav class="lc-nav" aria-label="Điều hướng chính">

          <a href="#gallery">Dự án</a>

          <a href="#about">Giới thiệu</a>

          <a href="#achievements">Thành tựu</a>

          <a href="#contact">Liên hệ</a>

        </nav>



        <div class="lc-header-actions">

          <a href="tel:+842812345678" class="lc-call">Gọi ngay</a>

          <div class="lc-socials" aria-label="Mạng xã hội">

            <a href="#" aria-label="Facebook">f</a>

            <a href="#" aria-label="Twitter">t</a>

            <a href="#" aria-label="Instagram">in</a>

          </div>

          <button type="button" class="lc-icon-btn" aria-label="Tìm kiếm">

            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3-3"/></svg>

            <span>Tìm kiếm</span>

          </button>

          <button type="button" class="lc-menu-btn" id="lc-menu-btn" aria-label="Menu" aria-expanded="false" aria-controls="lc-drawer">

            <span></span><span></span><span></span>

            <span class="lc-menu-label">Menu</span>

          </button>

        </div>

      </div>



      <nav class="lc-drawer" id="lc-drawer" aria-label="Menu di động" hidden>

        <a href="#gallery">Dự án</a>

        <a href="#about">Giới thiệu</a>

        <a href="#achievements">Thành tựu</a>

        <a href="#contact">Liên hệ</a>

      </nav>

    </header>



    <div class="lc-hero">

      <div class="lc-hero-bg">

        <img

          src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1600&q=80"

          alt="Đường chân trời thành phố lúc bình minh"

          width="1600"

          height="900"

        />

      </div>

      <div class="lc-hero-fade"></div>

      <div class="lc-wrap lc-hero-content" data-aos="fade-up" data-aos-duration="850">

        <h1 class="lc-hero-title">Hiện thực hóa giấc mơ cùng kiến trúc sư tài năng</h1>

        <a href="#gallery" class="lc-hero-cta">Xem dự án →</a>

      </div>

    </div>

  </section>



  <section class="lc-gallery" id="gallery">

    <div class="lc-wrap">

      <div class="lc-gallery-grid">

        <img

          src="https://images.unsplash.com/photo-1600607687644-c7171b42498f?auto=format&fit=crop&w=600&q=80"

          alt="Kiến trúc nhà ở hiện đại"

          width="400"

          height="400"

          loading="lazy"

          data-aos="fade-up"

          data-aos-delay="0"

        />

        <img

          src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=600&q=80"

          alt="Mặt tiền tòa nhà đương đại"

          width="400"

          height="400"

          loading="lazy"

          data-aos="fade-up"

          data-aos-delay="60"

        />

        <img

          src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?auto=format&fit=crop&w=600&q=80"

          alt="Ngoại thất biệt thự sang trọng"

          width="400"

          height="400"

          loading="lazy"

          data-aos="fade-up"

          data-aos-delay="120"

        />

      </div>

    </div>

  </section>



  <section class="lc-about" id="about">

    <div class="lc-wrap lc-about-grid">

      <div class="lc-about-copy" data-aos="fade-right" data-aos-duration="850">

        <p class="lc-section-kicker">Về chúng tôi <span class="lc-kicker-line">——</span></p>

        <h2 class="lc-about-title">

          Hơn 15 năm thiết kế hàng nghìn không gian thành công

        </h2>

        <p class="lc-about-text">

          LaCasa kết hợp kiến trúc sư tầm nhìn và đội ngũ thi công tỉ mỉ, mang đến những ngôi nhà cân bằng giữa thẩm mỹ, công năng và giá trị bền vững.

        </p>

        <a href="#process" class="lc-link-btn">Tìm hiểu thêm →</a>

      </div>

      <div class="lc-about-visual" data-aos="fade-left" data-aos-delay="110" data-aos-duration="850">

        <img

          src="https://images.unsplash.com/photo-1600047509807-ba8f99d2cdde?auto=format&fit=crop&w=800&q=80"

          alt="Ngoại thất tòa nhà hiện đại"

          width="640"

          height="480"

        />

      </div>

    </div>

  </section>



  <section class="lc-process" id="process">

    <div class="lc-wrap">

      <div class="lc-process-head" data-aos="fade-up">

        <p class="lc-section-kicker">Quy trình</p>

        <h2 class="lc-process-title">Ba bước kiến tạo tổ ấm</h2>

      </div>



      <ol class="lc-process-steps">

        <li class="lc-process-step" data-aos="fade-up" data-aos-delay="0">

          <span class="lc-process-num">01</span>

          <h3 class="lc-process-step-title">Tư vấn</h3>

          <p class="lc-process-step-text">Lắng nghe nhu cầu, khảo sát hiện trạng và đề xuất phương án phù hợp ngân sách.</p>

        </li>

        <li class="lc-process-step" data-aos="fade-up" data-aos-delay="60">

          <span class="lc-process-num">02</span>

          <h3 class="lc-process-step-title">Thiết kế</h3>

          <p class="lc-process-step-text">Phác thảo ý tưởng, bản vẽ 3D chi tiết và tinh chỉnh đến khi bạn hài lòng.</p>

        </li>

        <li class="lc-process-step" data-aos="fade-up" data-aos-delay="120">

          <span class="lc-process-num">03</span>

          <h3 class="lc-process-step-title">Thi công</h3>

          <p class="lc-process-step-text">Giám sát chất lượng, tiến độ và bàn giao đúng cam kết — sẵn sàng đón nhận gia đình bạn.</p>

        </li>

      </ol>

    </div>

  </section>



  <section class="lc-achievements" id="achievements">

    <div class="lc-wrap lc-achievements-grid">

      <div class="lc-achievements-visual" data-aos="fade-right" data-aos-duration="850">

        <img

          src="https://images.unsplash.com/photo-1480714378408-67cf0d13bc1b?auto=format&fit=crop&w=800&q=80"

          alt="Những tòa nhà chọc trời trong thành phố"

          width="640"

          height="720"

        />

      </div>

      <div class="lc-achievements-copy" data-aos="fade-left" data-aos-delay="110" data-aos-duration="850">

        <p class="lc-section-kicker">Thành tựu</p>

        <h2 class="lc-achievements-title">Thành tựu của chúng tôi</h2>

        <div class="lc-stats">

          {{#each stats}}

          <div class="lc-stat" data-aos="fade-up" data-aos-delay="{{multiply @index 60}}">

            <span class="lc-stat-value">{{this.value}}</span>

            <span class="lc-stat-label">{{this.label}}</span>

          </div>

          {{/each}}

        </div>

      </div>

    </div>

  </section>



  <section class="lc-contact" id="contact">

    <div class="lc-wrap lc-contact-inner">

      <div class="lc-contact-copy" data-aos="fade-right" data-aos-duration="850">

        <p class="lc-section-kicker">Liên hệ</p>

        <h2 class="lc-contact-title">Đặt lịch tư vấn miễn phí</h2>

        <p class="lc-contact-text">

          Để lại thông tin, kiến trúc sư LaCasa sẽ liên hệ trong vòng 24 giờ để thảo luận ý tưởng và lộ trình thực hiện.

        </p>

      </div>



      <form class="lc-contact-form" action="#" onsubmit="return false" data-aos="fade-left" data-aos-delay="110" data-aos-duration="850">

        <label class="lc-field">

          <span>Họ tên</span>

          <input type="text" name="name" placeholder="Nguyễn Văn A" required />

        </label>

        <label class="lc-field">

          <span>Số điện thoại</span>

          <input type="tel" name="phone" placeholder="0901 234 567" required />

        </label>

        <label class="lc-field lc-field-full">

          <span>Nội dung</span>

          <textarea name="message" rows="4" placeholder="Tôi muốn tư vấn thiết kế nhà phố..."></textarea>

        </label>

        <button type="submit" class="lc-btn">Gửi yêu cầu</button>

      </form>

    </div>

  </section>



  <footer class="lc-footer">

    <div class="lc-wrap lc-footer-inner">

      <div class="lc-footer-brand">

        <span class="lc-logo-mark">LaCasa</span>

        <span class="lc-logo-sub">tổ ấm ngọt ngào</span>

      </div>

      <nav class="lc-footer-nav" aria-label="Liên kết chân trang">

        <a href="#gallery">Dự án</a>

        <a href="#about">Giới thiệu</a>

        <a href="#achievements">Thành tựu</a>

        <a href="#contact">Liên hệ</a>

      </nav>

      <div class="lc-footer-contact">

        <p><a href="tel:+842812345678">+84 28 1234 5678</a></p>

        <p>hello@lacasa.vn</p>

      </div>

    </div>

    <p class="lc-footer-copy">© 2026 LaCasa. Bản demo thiết kế bởi Honize.</p>

  </footer>

</div>



<script>

  (function () {

    var menuBtn = document.getElementById('lc-menu-btn');

    var drawer = document.getElementById('lc-drawer');

    if (!menuBtn || !drawer) return;



    function closeDrawer() {

      drawer.hidden = true;

      menuBtn.setAttribute('aria-expanded', 'false');

      document.body.classList.remove('lc-drawer-open');

    }



    menuBtn.addEventListener('click', function () {

      var open = drawer.hidden;

      drawer.hidden = !open;

      menuBtn.setAttribute('aria-expanded', open ? 'true' : 'false');

      document.body.classList.toggle('lc-drawer-open', open);

    });



    drawer.querySelectorAll('a').forEach(function (link) {

      link.addEventListener('click', closeDrawer);

    });

  })();

</script>

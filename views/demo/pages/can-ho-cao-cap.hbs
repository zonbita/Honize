{{> demo/toolbar }}



<div class="to-page">



  <section class="to-hero" id="home">



    <div class="to-hero-overlay" aria-hidden="true"></div>



    <header class="to-header">



      <nav class="to-nav to-nav-left" aria-label="Điều hướng trái">



        <a href="#home">Trang chủ</a>



        <a href="#units">Căn hộ</a>



        <a href="#features">Tiện ích</a>



      </nav>



      <a href="/du-an/demo/can-ho-cao-cap" class="to-logo">the origami</a>



      <nav class="to-nav to-nav-right" aria-label="Điều hướng phải">



        <a href="#about">Vị trí</a>



        <a href="#features">Đầu tư</a>



        <a href="#contact">Liên hệ</a>



      </nav>



    </header>



    <div class="to-hero-content" data-aos="fade-up" data-aos-duration="850">



      <h1 class="to-hero-title">Không gian sống tinh tế giữa lòng đô thị</h1>



      <p class="to-hero-text">



        Dự án căn hộ cao cấp với thiết kế độc đáo, tiện ích đầy đủ và tầm nhìn mở rộng.



      </p>



      <a href="#units" class="to-btn">Khám phá dự án</a>



    </div>



  </section>



  <section class="to-about" id="about">



    <div class="to-about-inner">



      <div class="to-about-copy" data-aos="fade-right" data-aos-duration="850">



        <h2 class="to-about-title"><span class="to-gold">Tầm nhìn</span> kiến trúc</h2>



        <p>



          Chúng tôi kiến tạo không gian sống đẳng cấp, nơi kiến trúc hiện đại hòa quyện với thiên nhiên và tiện ích cao cấp. Mỗi căn hộ được thiết kế tối ưu ánh sáng, thông gió và trải nghiệm sống riêng tư giữa đô thị.



        </p>



        <p>



          Từ sảnh đón khách sang trọng đến khu vực sinh hoạt chung, mọi chi tiết đều hướng tới phong cách sống tinh tế — nơi gia đình tận hưởng sự thoải mái, an toàn và giá trị bền vững theo thời gian.



        </p>



      </div>



      <div class="to-about-media" data-aos="fade-left" data-aos-delay="110" data-aos-duration="850">



        <img



          src="https://images.unsplash.com/photo-1514565131-fce0801e5785?auto=format&fit=crop&w=900&h=600&q=80"



          alt="Công viên thành phố với cầu và đường chân trời"



          width="560"



          height="380"



        />



        <button type="button" class="to-play" aria-label="Phát video">



          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">



            <path d="M8 5v14l11-7z"/>



          </svg>



        </button>



      </div>



    </div>



  </section>



  <section class="to-units" id="units">



    <div class="to-units-inner">



      <div class="to-units-head" data-aos="fade-up">



        <p class="to-units-kicker">Căn hộ mẫu</p>



        <h2 class="to-units-title">Lựa chọn phù hợp mọi nhu cầu</h2>



      </div>



      <div class="to-units-grid">



        <article class="to-unit-card" data-aos="fade-up" data-aos-delay="0">



          <div class="to-unit-media">



            <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?auto=format&fit=crop&w=600&h=400&q=80" alt="Căn hộ Studio 45m²" loading="lazy" width="400" height="260" />



          </div>



          <div class="to-unit-body">



            <h3 class="to-unit-name">Studio</h3>



            <p class="to-unit-size">45m² · 1 phòng ngủ mở</p>



            <p class="to-unit-price">Từ <span>2,1 tỷ</span></p>



            <a href="#contact" class="to-unit-link">Đặt lịch xem →</a>



          </div>



        </article>



        <article class="to-unit-card" data-aos="fade-up" data-aos-delay="60">



          <div class="to-unit-media">



            <img src="https://images.unsplash.com/photo-1560448204-e02f11c457d2?auto=format&fit=crop&w=600&h=400&q=80" alt="Căn hộ 2 phòng ngủ 75m²" loading="lazy" width="400" height="260" />



          </div>



          <div class="to-unit-body">



            <h3 class="to-unit-name">2 phòng ngủ</h3>



            <p class="to-unit-size">75m² · ban công rộng</p>



            <p class="to-unit-price">Từ <span>3,4 tỷ</span></p>



            <a href="#contact" class="to-unit-link">Đặt lịch xem →</a>



          </div>



        </article>



        <article class="to-unit-card" data-aos="fade-up" data-aos-delay="120">



          <div class="to-unit-media">



            <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=600&h=400&q=80" alt="Căn hộ 3 phòng ngủ 110m²" loading="lazy" width="400" height="260" />



          </div>



          <div class="to-unit-body">



            <h3 class="to-unit-name">3 phòng ngủ</h3>



            <p class="to-unit-size">110m² · góc view thành phố</p>



            <p class="to-unit-price">Từ <span>5,2 tỷ</span></p>



            <a href="#contact" class="to-unit-link">Đặt lịch xem →</a>



          </div>



        </article>



      </div>



    </div>



  </section>



  <section class="to-features" id="features">



    <div class="to-features-inner">



      {{#each features}}



      <article class="to-feature" data-aos="fade-up" data-aos-delay="{{multiply @index 60}}">



        <div class="to-feature-icon">{{{this.icon}}}</div>



        <h3 class="to-feature-title">{{this.title}}</h3>



        <p class="to-feature-text">{{this.text}}</p>



      </article>



      {{/each}}



    </div>



  </section>



  <section class="to-contact" id="contact" aria-label="Đặt lịch tham quan">



    <div class="to-contact-inner" data-aos="fade-up">



      <div class="to-contact-copy">



        <p class="to-units-kicker">Liên hệ</p>



        <h2 class="to-contact-title">Đặt lịch tham quan</h2>



        <p class="to-contact-text">Trải nghiệm không gian sống the origami — đội ngũ tư vấn sẽ liên hệ xác nhận lịch hẹn.</p>



      </div>



      <form class="to-contact-form" action="#" onsubmit="return false">



        <label class="to-field">



          <span>Họ tên</span>



          <input type="text" name="name" placeholder="Nguyễn Văn A" required />



        </label>



        <label class="to-field">



          <span>Email</span>



          <input type="email" name="email" placeholder="email@example.com" required />



        </label>



        <label class="to-field">



          <span>Số điện thoại</span>



          <input type="tel" name="phone" placeholder="0901 234 567" required />



        </label>



        <label class="to-field to-field-full">



          <span>Ghi chú</span>



          <textarea name="message" rows="3" placeholder="Tôi muốn tham quan căn hộ..."></textarea>



        </label>



        <button type="submit" class="to-btn">Gửi yêu cầu</button>



      </form>



    </div>



  </section>



  <footer class="to-footer">



    <div class="to-footer-inner">



      <div class="to-footer-brand">



        <a href="/du-an/demo/can-ho-cao-cap" class="to-logo to-logo-footer">the origami</a>



        <p class="to-footer-tagline">Căn hộ cao cấp — phong cách sống tinh tế.</p>




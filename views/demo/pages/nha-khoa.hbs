<div class="oris-page oris-page--home">
  {{> demo/oris/header }}

  <section class="oris-hero" id="oris-hero" aria-label="Banner chính">
    <div class="oris-hero-bg">
      <img
        src="/images/Demo/NhaKhoa/02-hero-smile.png"
        alt="Đội ngũ bác sĩ nha khoa thẩm mỹ ORIS"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="oris-hero-overlay" aria-hidden="true"></div>
    <div class="oris-hero-inner">
      {{> demo/oris/hero-content }}
    </div>
    {{> demo/oris/stats-panel }}
  </section>

  {{> demo/oris/services-section }}
  {{> demo/oris/about-section }}
  {{> demo/oris/technology-section }}
  {{> demo/oris/results-section }}
  {{> demo/oris/doctors-section }}
  {{> demo/oris/testimonials-section }}
  {{> demo/oris/appointment-section }}

  <a href="tel:19002888" class="oris-sticky-call" aria-label="Gọi hotline ORIS 1900 2888">
    <span class="oris-sticky-call-icon" aria-hidden="true">☎</span>
    <span>Gọi ngay</span>
  </a>

  {{> demo/oris/footer }}
</div>

{{> demo/oris/scripts }}

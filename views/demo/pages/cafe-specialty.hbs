<script>
  (() => {
    const page = document.querySelector('.cf-page');
    if (!page) return;

    const toggle = page.querySelector('.cf-menu-toggle');
    const nav = page.querySelector('.cf-nav');
    const form = page.querySelector('.cf-form');

    toggle?.addEventListener('click', () => {
      const isOpen = page.classList.toggle('is-menu-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    nav?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        page.classList.remove('is-menu-open');
        toggle?.setAttribute('aria-expanded', 'false');
      });
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      const status = form.querySelector('.cf-form-status');
      if (status) status.textContent = 'Cảm ơn bạn. Oria sẽ xác nhận đơn trong ít phút.';
      form.reset();
    });
  })();
</script>

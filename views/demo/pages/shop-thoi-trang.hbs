{{> demo/toolbar }}



<div class="fs-page">



  <div class="fs-wrap">



    <header class="fs-header">



      <a href="/du-an/demo/shop-thoi-trang" class="fs-logo" aria-label="FastShop">



        <svg class="fs-logo-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">



          <path d="M6 7V6a6 6 0 1112 0v1h2.2a1 1 0 01.98 1.2l-1.5 7.5A3 3 0 0116.72 18H7.28a3 3 0 01-2.96-2.3L2.82 8.2A1 1 0 013.8 7H6zm2 0h8V6a4 4 0 10-8 0v1z"/>



        </svg>



        FastShop



      </a>



      <ul class="fs-nav">



        <li><a href="#best">Nam</a></li>



        <li><a href="#best" class="is-active">Nữ</a></li>



        <li><a href="#best">Phụ kiện</a></li>



        <li><a href="#best">Hè</a></li>



        <li><a href="#best">Sale</a></li>



      </ul>



      <div class="fs-actions">



        <button type="button" class="fs-icon-btn" aria-label="Tìm kiếm">



          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3-3"/></svg>



        </button>



        <button type="button" class="fs-icon-btn" aria-label="Giỏ hàng">



          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 7h15l-1.5 9H8L6 7z"/><path d="M6 7L5 3H2"/><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/></svg>



          <span class="fs-badge">0</span>



        </button>



      </div>



    </header>



    <section class="fs-hero">



      <div class="fs-hero-copy" data-aos="fade-right" data-aos-duration="850">



        <p class="fs-hero-eyebrow">Thời trang hè dành cho nữ</p>



        <h1 class="fs-hero-title">Bộ sưu tập 2026 cho phái đẹp</h1>



        <p class="fs-hero-text">



          Khám phá những thiết kế nổi bật mùa hè — chất liệu nhẹ, phom dáng hiện đại, dễ phối mỗi ngày.



        </p>



        <a href="#best" class="fs-btn">Mua ngay</a>



        <div class="fs-social">



          <a href="#" aria-label="Instagram">



            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M7 3h10a4 4 0 014 4v10a4 4 0 01-4 4H7a4 4 0 01-4-4V7a4 4 0 014-4zm5 3.5A4.5 4.5 0 1016.5 11 4.5 4.5 0 0012 6.5zm0 2A2.5 2.5 0 1114.5 11 2.5 2.5 0 0112 8.5zm5.25-2.75a1 1 0 11-1 1 1 1 0 011-1z"/></svg>



          </a>



          <a href="#" aria-label="Twitter">



            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 5.8a8.2 8.2 0 01-2.36.65A4.1 4.1 0 0021.4 4a8.25 8.25 0 01-2.6 1A4.12 4.12 0 0015.1 4a4.12 4.12 0 00-4.1 5.1A11.67 11.67 0 013 4.8a4.12 4.12 0 001.27 5.5 4.08 4.08 0 01-1.86-.5v.05A4.12 4.12 0 006.5 13.9a4.14 4.14 0 01-1.85.07 4.12 4.12 0 003.84 2.86A8.26 8.26 0 012 18.3a11.64 11.64 0 006.29 1.84c7.55 0 11.68-6.26 11.68-11.68v-.53A8.28 8.28 0 0022 5.8z"/></svg>



          </a>



          <a href="#" aria-label="Facebook">



            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H8v3h3v7h3v-7h3l1-3h-4V9c0-.6.4-1 1-1z"/></svg>



          </a>



        </div>



      </div>



      <div class="fs-hero-visual">



        <span class="fs-hero-circle" aria-hidden="true"></span>



        <span class="fs-hero-wave" aria-hidden="true"></span>



        <span class="fs-dot fs-dot-a" aria-hidden="true"></span>



        <span class="fs-dot fs-dot-b" aria-hidden="true"></span>



        <span class="fs-dot fs-dot-c" aria-hidden="true"></span>



        <div class="fs-rating-card" data-aos="fade-left" data-aos-delay="110" data-aos-duration="850">



          <p>Đánh giá</p>



          <div class="fs-rating-emojis" aria-hidden="true">👍 ❤️ 😊 😮 😢</div>



        </div>



        <img



          class="fs-hero-img"



          data-aos="fade-left"



          data-aos-delay="110"



          data-aos-duration="850"



          src="https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=900&q=80"



          alt="Người mẫu thời trang hè với túi mua sắm"



          width="560"



          height="700"



        />



        <svg class="fs-leaf" viewBox="0 0 64 64" aria-hidden="true">



          <path fill="#4caf50" d="M48 8C28 10 12 28 12 48c18-2 34-18 36-40z"/>



          <path fill="#2e7d32" d="M20 44c10-10 20-16 28-18-4 12-14 24-28 28 2-4 2-7 0-10z"/>



        </svg>



      </div>



    </section>



    <section class="fs-best" id="best">



      <div class="fs-best-head" data-aos="fade-up">



        <p class="fs-best-kicker">Nổi bật</p>



        <h2 class="fs-best-title">Bán chạy nhất</h2>



      </div>



      <ul class="fs-filters" id="fs-filters">



        <li><button type="button" class="is-active" data-filter="all">Tất cả</button></li>



        <li><button type="button" data-filter="a">Áo</button></li>



        <li><button type="button" data-filter="b">Váy</button></li>



        <li><button type="button" data-filter="c">Quần</button></li>



        <li><button type="button" data-filter="d">Phụ kiện</button></li>



      </ul>



      <div class="fs-grid">



        {{#each products}}



        <a href="#" class="fs-card" data-cat="{{this.cat}}" data-aos="fade-up" data-aos-delay="{{multiply @index 60}}">



          <div class="fs-card-media" style="background:{{this.bg}}">



            <img src="{{{this.image}}}" alt="{{this.title}}" loading="lazy" width="400" height="400" />



          </div>



          <h3 class="fs-card-title">{{this.title}}</h3>



          <div class="fs-card-meta">



            <p class="fs-card-price">{{this.price}}</p>



            <span class="fs-stars" aria-label="5 sao">★★★★★</span>



          </div>



        </a>



        {{/each}}



      </div>



    </section>



    <section class="fs-promo" id="promo" data-aos="fade-up">



      <div class="fs-promo-inner">



        <div class="fs-promo-copy">



          <h2 class="fs-promo-title">Nhận ưu đãi mùa hè</h2>



          <p class="fs-promo-text">Đăng ký email để nhận mã giảm giá 15% cho đơn hàng đầu tiên.</p>



        </div>



        <form class="fs-promo-form" action="#" onsubmit="return false">



          <input type="email" name="email" placeholder="Email của bạn" aria-label="Email của bạn" required />



          <button type="submit" class="fs-btn fs-btn-sm">Đăng ký</button>



        </form>



      </div>



    </section>



    <section class="fs-contact" id="contact" aria-label="Liên hệ">



      <div class="fs-contact-inner" data-aos="fade-up">



        <div class="fs-contact-copy">



          <p class="fs-best-kicker">Liên hệ</p>



          <h2 class="fs-contact-title">Cần tư vấn chọn size?</h2>



          <p class="fs-contact-text">Để lại thông tin, đội ngũ FastShop sẽ phản hồi trong vòng 24 giờ.</p>



        </div>



        <form class="fs-contact-form" action="#" onsubmit="return false">



          <label class="fs-field">



            <span>Họ tên</span>



            <input type="text" name="name" placeholder="Nguyễn Văn A" required />



          </label>



          <label class="fs-field">



            <span>Số điện thoại</span>



            <input type="tel" name="phone" placeholder="0901 234 567" required />



          </label>



          <label class="fs-field fs-field-full">



            <span>Tin nhắn</span>



            <textarea name="message" rows="3" placeholder="Tôi muốn tư vấn về..."></textarea>



          </label>



          <button type="submit" class="fs-btn">Gửi yêu cầu</button>



        </form>



      </div>



    </section>



  </div>



  <footer class="fs-footer">



    <div class="fs-wrap fs-footer-inner">



      <div class="fs-footer-brand">



        <a href="/du-an/demo/shop-thoi-trang" class="fs-logo" aria-label="FastShop">



          <svg class="fs-logo-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">



            <path d="M6 7V6a6 6 0 1112 0v1h2.2a1 1 0 01.98 1.2l-1.5 7.5A3 3 0 0116.72 18H7.28a3 3 0 01-2.96-2.3L2.82 8.2A1 1 0 013.8 7H6zm2 0h8V6a4 4 0 10-8 0v1z"/>



          </svg>



          FastShop



        </a>



        <p class="fs-footer-tagline">Thời trang nữ hiện đại — phong cách mỗi ngày.</p>



      </div>



      <nav class="fs-footer-nav" aria-label="Liên kết chân trang">



        <a href="#best">Sản phẩm</a>



        <a href="#promo">Ưu đãi</a>



        <a href="#contact">Liên hệ</a>



      </nav>



      <div class="fs-footer-contact">



        <p><a href="tel:19001234">1900 1234</a></p>



        <p>support@fastshop.vn</p>



      </div>



    </div>



    <p class="fs-footer-copy">© 2026 FastShop. Bản demo thiết kế bởi Honize.</p>



  </footer>



</div>



<script>



  (function () {



    var filters = document.getElementById('fs-filters');



    if (!filters) return;



    filters.addEventListener('click', function (e) {



      var btn = e.target.closest('button');



      if (!btn) return;



      filters.querySelectorAll('button').forEach(function (b) { b.classList.remove('is-active'); });



      btn.classList.add('is-active');



      var key = btn.getAttribute('data-filter') || 'all';



      document.querySelectorAll('.fs-card').forEach(function (card) {



        var cat = card.getAttribute('data-cat') || 'all';



        card.style.display = (key === 'all' || key === cat) ? '' : 'none';



      });



    });



  })();



</script>



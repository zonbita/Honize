<header class="sticky top-0 z-50 bg-white/95 shadow-nav backdrop-blur-md">
  <div class="border-b border-slate-100">
    <div class="container-main flex items-center justify-between py-3">
      <a href="/" class="flex items-center gap-2">
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-600 text-lg font-bold text-white">H</span>
        <span class="text-xl font-bold text-brand-800">{{brand}}</span>
      </a>

      <div class="hidden items-center gap-6 lg:flex">
        <a href="tel:{{phone}}" class="flex items-center gap-2 text-sm text-slate-600 hover:text-brand-600">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {{phone}}
        </a>
        <a href="mailto:{{email}}" class="flex items-center gap-2 text-sm text-slate-600 hover:text-brand-600">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          {{email}}
        </a>
        <a href="#contact" class="btn-primary !px-6 !py-2">Liên Hệ</a>
      </div>

      <button id="menu-btn" class="rounded-lg p-2 text-slate-600 hover:bg-slate-100 lg:hidden" aria-label="Menu">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <nav class="container-main hidden py-4 lg:block">
    <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2">
      {{#each nav}}
      <li class="relative group">
        <a href="{{this.href}}" class="nav-link">{{this.label}}</a>
        {{#if this.children}}
        <div class="invisible absolute left-0 top-full z-50 min-w-[200px] rounded-xl bg-white py-2 opacity-0 shadow-card transition-all group-hover:visible group-hover:opacity-100">
          {{#each this.children}}
          <a href="{{this.href}}" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-50 hover:text-brand-700">{{this.label}}</a>
          {{/each}}
        </div>
        {{/if}}
      </li>
      {{/each}}
    </ul>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-slate-100 bg-white lg:hidden">
    <div class="container-main space-y-1 py-4">
      {{#each nav}}
      <a href="{{this.href}}" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-brand-50 hover:text-brand-700">{{this.label}}</a>
      {{/each}}
      <div class="mt-4 space-y-2 border-t border-slate-100 pt-4">
        <a href="tel:{{phone}}" class="block text-sm text-slate-600">{{phone}}</a>
        <a href="mailto:{{email}}" class="block text-sm text-slate-600">{{email}}</a>
        <a href="#contact" class="btn-primary mt-2 w-full">Liên Hệ</a>
      </div>
    </div>
  </div>
</header>

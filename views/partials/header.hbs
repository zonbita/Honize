<header class="site-header">
  <div class="header-float">
    <div class="header-inner">
      <a href="/" class="header-logo">
        <img src="/images/logo.png" alt="{{brand}}" class="h-10 w-auto max-w-[160px] object-contain object-left md:h-11" />
      </a>

      <nav class="header-menus" aria-label="Menu chính">
        <ul class="header-nav">
          {{#each nav}}
          <li class="relative group">
            <a
              href="{{this.href}}"
              class="nav-link{{#if (eq ../currentPath this.href)}} is-active{{/if}}"
            >{{this.label}}</a>
            {{#if this.children}}
            <div class="header-dropdown">
              {{#each this.children}}
              <a href="{{this.href}}" class="header-dropdown-link">{{this.label}}</a>
              {{/each}}
            </div>
            {{/if}}
          </li>
          {{/each}}
        </ul>
      </nav>

      <div class="header-trailing">
        <a href="/#banggia" class="header-cta">
          Báo giá ngay
          <svg class="header-cta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <button id="menu-btn" class="header-menu-btn" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="header-mobile hidden" hidden>
    <div class="header-mobile-inner">
      {{#each nav}}
      <a href="{{this.href}}" class="header-mobile-link">{{this.label}}</a>
      {{/each}}
      <a href="/#banggia" class="header-mobile-cta">Báo giá ngay</a>
      <div class="header-mobile-meta">
        <a href="tel:{{phone}}">{{phone}}</a>
        <a href="mailto:{{email}}">{{email}}</a>
      </div>
    </div>
  </div>
</header>

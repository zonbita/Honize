<header class="vivu-header{{#if vivuHeaderSolid}} is-solid is-scrolled{{/if}}" id="vivu-header">
  <div class="vivu-container vivu-header-inner">
    <a href="{{vivuBase}}" class="vivu-logo" aria-label="VIVU — Trang chủ">
      <svg class="vivu-logo-icon" viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
        <circle cx="16" cy="16" r="13" fill="none" stroke="currentColor" stroke-width="1.5"/>
        <polygon points="16,6 18,14 16,12 14,14" fill="currentColor"/>
        <line x1="16" y1="16" x2="16" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span class="vivu-logo-text">VIVU</span>
    </a>

    <nav class="vivu-nav" id="vivu-nav" aria-label="Menu chính">
      <a href="{{vivuBase}}" class="{{#if (eq vivuActive 'home')}}is-active{{/if}}">Trang chủ</a>
      <a href="{{vivuBase}}/diem-den" class="{{#if (eq vivuActive 'destinations')}}is-active{{/if}}">Điểm đến</a>
      <a href="{{vivuBase}}/tour-du-lich" class="{{#if (eq vivuActive 'tours')}}is-active{{/if}}">Tour du lịch</a>
      <a href="{{vivuBase}}/trai-nghiem" class="{{#if (eq vivuActive 'experiences')}}is-active{{/if}}">Trải nghiệm</a>
      <a href="{{vivuBase}}/cam-nang" class="{{#if (eq vivuActive 'handbook')}}is-active{{/if}}">Cẩm nang</a>
      <a href="{{vivuBase}}/lien-he" class="{{#if (eq vivuActive 'contact')}}is-active{{/if}}">Liên hệ</a>
    </nav>

    <div class="vivu-header-actions">
      <button type="button" class="vivu-lang-btn" aria-label="Ngôn ngữ">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="18" height="18" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20"/>
        </svg>
        VN
        <svg class="vivu-lang-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" aria-hidden="true">
          <path d="M6 9l6 6 6-6"/>
        </svg>
      </button>
      <a href="{{vivuBase}}/lien-he" class="vivu-btn vivu-btn-primary">Đặt tour</a>
    </div>

    <button type="button" class="vivu-menu-btn" id="vivu-menu-btn" aria-label="Menu" aria-expanded="false" aria-controls="vivu-nav">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<header class="oris-header{{#if orisHeaderSolid}} oris-header--solid{{/if}}" id="oris-header">
  <div class="oris-header-bar">
    <a href="{{orisBase}}" class="oris-logo" aria-label="ORIS — Trang chủ">
      <svg class="oris-logo-mark" viewBox="0 0 40 40" width="44" height="44" aria-hidden="true">
        <circle cx="20" cy="20" r="20" fill="#0787D5"/>
        <path d="M20 9.5c3.2 3.6 5.2 7 5.2 10.4a5.2 5.2 0 11-10.4 0c0-3.4 2-6.8 5.2-10.4z" fill="#fff"/>
        <circle cx="20" cy="19.8" r="2" fill="#0787D5"/>
      </svg>
      <span class="oris-logo-text">
        <span class="oris-logo-name">ORIS</span>
        <span class="oris-logo-sub">NHA KHOA THẨM MỸ</span>
      </span>
    </a>

    <nav class="oris-nav" id="oris-nav" aria-label="Menu chính">
      {{#each orisNav}}
        <a href="{{href}}" class="{{#if (eq ../orisActive key)}}is-active{{/if}}">{{label}}</a>
      {{/each}}
      <div class="oris-nav-actions">
        <a href="tel:19002888" class="oris-header-phone" aria-label="Gọi 1900 2888">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M7.2 4.8c.5-1 1.6-1.4 2.6-1l1.8.7c.9.3 1.3 1.3 1 2.2l-.7 1.8c-.2.5 0 1 .4 1.4l2.8 2.8c.4.4.9.6 1.4.4l1.8-.7c.9-.3 1.9.1 2.2 1l.7 1.8c.4 1 0 2.1-1 2.6-2.4 1.3-7.4.6-11.3-3.3S5.9 7.2 7.2 4.8z"/>
          </svg>
          <span>1900 2888</span>
        </a>
        <a href="{{orisBase}}#booking" class="oris-btn oris-btn-primary oris-nav-cta">Đặt hẹn ngay</a>
      </div>
    </nav>

    <div class="oris-header-actions">
      <a href="tel:19002888" class="oris-header-phone" aria-label="Gọi 1900 2888">
        <svg class="oris-header-phone-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M7.2 4.8c.5-1 1.6-1.4 2.6-1l1.8.7c.9.3 1.3 1.3 1 2.2l-.7 1.8c-.2.5 0 1 .4 1.4l2.8 2.8c.4.4.9.6 1.4.4l1.8-.7c.9-.3 1.9.1 2.2 1l.7 1.8c.4 1 0 2.1-1 2.6-2.4 1.3-7.4.6-11.3-3.3S5.9 7.2 7.2 4.8z"/>
        </svg>
        <span class="oris-header-phone-text">1900 2888</span>
      </a>
      <a href="{{orisBase}}#booking" class="oris-btn oris-btn-primary oris-header-cta">Đặt hẹn ngay</a>
    </div>

    <a href="tel:19002888" class="oris-header-phone-mobile" aria-label="Gọi 1900 2888">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M7.2 4.8c.5-1 1.6-1.4 2.6-1l1.8.7c.9.3 1.3 1.3 1 2.2l-.7 1.8c-.2.5 0 1 .4 1.4l2.8 2.8c.4.4.9.6 1.4.4l1.8-.7c.9-.3 1.9.1 2.2 1l.7 1.8c.4 1 0 2.1-1 2.6-2.4 1.3-7.4.6-11.3-3.3S5.9 7.2 7.2 4.8z"/>
      </svg>
    </a>

    <button type="button" class="oris-menu-btn" id="oris-menu-btn" aria-label="Mở menu" aria-expanded="false" aria-controls="oris-nav">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<a href="{{href}}" class="oris-doc-card">
  <div class="oris-doc-card-media">
    <img src="{{image}}" alt="{{name}}" width="480" height="600" loading="lazy" />
  </div>
  <div class="oris-doc-card-body">
    <h3>{{name}}</h3>
    <p class="oris-doc-role">{{role}}</p>
    <span class="oris-doc-link">Xem hồ sơ <span aria-hidden="true">→</span></span>
  </div>
</a>

<div class="el-promo" role="region" aria-label="Khuyến mãi">
  <p>Giảm đến 50% BST Xuân Hè — Miễn phí vận chuyển đơn từ 599.000đ</p>
</div>

<header class="el-header{{#if elaraHeaderSolid}} is-solid{{/if}}" id="el-header">
  <div class="el-wrap el-header-inner">
    <button type="button" class="el-menu-toggle" id="el-menu-toggle" aria-expanded="false" aria-controls="el-nav">
      <span></span><span></span><span></span>
      <span class="sr-only">Mở menu</span>
    </button>

    <a href="{{elaraBase}}" class="el-logo" aria-label="ÉLARA - Trang chủ">
      <span class="el-logo-mark" aria-hidden="true">É</span>
      <span class="el-logo-text">ÉLARA</span>
    </a>

    <nav class="el-nav" id="el-nav" aria-label="Điều hướng chính">
      <a href="{{elaraBase}}/ao" class="{{#if (eq elaraActive 'ao')}}is-active{{/if}}">Áo</a>
      <a href="{{elaraBase}}/vay" class="{{#if (eq elaraActive 'vay')}}is-active{{/if}}">Váy</a>
      <a href="{{elaraBase}}/quan" class="{{#if (eq elaraActive 'quan')}}is-active{{/if}}">Quần</a>
      <a href="{{elaraBase}}/phu-kien" class="{{#if (eq elaraActive 'phu-kien')}}is-active{{/if}}">Phụ kiện</a>
      <a href="{{elaraBase}}/bst" class="{{#if (eq elaraActive 'bst')}}is-active{{/if}}">BST mới</a>
      <a href="{{elaraBase}}/sale" class="{{#if (eq elaraActive 'sale')}}is-active{{/if}}">Sale</a>
      <a href="{{elaraBase}}/lien-he" class="{{#if (eq elaraActive 'contact')}}is-active{{/if}}">Liên hệ</a>
    </nav>

    <div class="el-actions">
      <button type="button" class="el-icon-btn" id="el-search-btn" aria-label="Tìm kiếm" aria-expanded="false" aria-controls="el-search-panel">
        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3-3"/></svg>
      </button>
      <button type="button" class="el-icon-btn" id="el-wish-btn" aria-label="Yêu thích">
        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M12 20.5l-1.1-1C5.5 14.8 2 11.6 2 7.8 2 5 4.2 3 6.8 3c1.6 0 3.1.8 4.2 2.1C12.1 3.8 13.6 3 15.2 3 17.8 3 20 5 20 7.8c0 3.8-3.5 7-8.9 11.7L12 20.5z"/></svg>
        <span class="el-badge el-badge-wish" hidden>0</span>
      </button>
      <button type="button" class="el-icon-btn el-icon-btn-cart" id="el-cart-btn" aria-label="Giỏ hàng" aria-expanded="false" aria-controls="el-cart-panel">
        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M6 7h15l-1.5 9H8L6 7z"/><path d="M6 7L5 3H2"/><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/></svg>
        <span class="el-badge" id="el-cart-count">0</span>
      </button>
    </div>
  </div>

  <div class="el-search-panel" id="el-search-panel" hidden>
    <div class="el-wrap el-search-inner">
      <label class="sr-only" for="el-search-input">Tìm sản phẩm</label>
      <input id="el-search-input" type="search" placeholder="Tìm áo, váy, quần, phụ kiện…" autocomplete="off" />
      <button type="button" class="el-btn el-btn-primary el-btn-sm" id="el-search-go">Tìm</button>
    </div>
  </div>
</header>

<aside class="el-cart-panel" id="el-cart-panel" hidden aria-label="Giỏ hàng">
  <div class="el-cart-panel-head">
    <strong>Giỏ hàng</strong>
    <button type="button" class="el-icon-btn" id="el-cart-close" aria-label="Đóng giỏ hàng">×</button>
  </div>
  <div class="el-cart-panel-body" id="el-cart-body">
    <p class="el-cart-empty">Chưa có sản phẩm nào.</p>
  </div>
  <div class="el-cart-panel-foot">
    <p>Tạm tính: <strong id="el-cart-total">0đ</strong></p>
    <a href="{{elaraBase}}/lien-he" class="el-btn el-btn-primary">Thanh toán / tư vấn</a>
  </div>
</aside>
<div class="el-cart-backdrop" id="el-cart-backdrop" hidden></div>
<div class="el-toast" id="el-toast" hidden role="status"></div>

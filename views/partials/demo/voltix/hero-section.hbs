<section class="vx-hero" id="hero" aria-label="Banner chính">
  <div class="vx-hero-bg" aria-hidden="true">
    <img src="/images/Demo/DienTu/hero-background.png" alt="" width="1920" height="620" loading="eager" />
  </div>
  <div class="vx-wrap vx-hero-inner">
    <div class="vx-hero-copy">
      <h1 class="vx-hero-title">
        <span class="vx-hero-title-line">Công nghệ</span>
        <span class="vx-hero-title-gradient">dẫn lối tương lai</span>
      </h1>
      <p class="vx-hero-text">Khám phá những sản phẩm công nghệ đỉnh cao, chính hãng, giá tốt và trải nghiệm mua sắm tuyệt vời.</p>
      <div class="vx-hero-actions">
        <a href="#products" class="vx-btn vx-btn-primary">
          Mua sắm ngay
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="#promotion" class="vx-btn vx-btn-outline">
          Khám phá thêm
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      {{> demo/voltix/trust-benefit }}
    </div>
    <div class="vx-hero-visual">
      <img
        class="vx-hero-products"
        src="/images/Demo/DienTu/hero-products-transparent.png"
        alt="Laptop, điện thoại, smartwatch và tai nghe trên nền tảng phát sáng"
        width="720"
        height="520"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>
  <div class="vx-hero-dots" aria-hidden="true">
    <span class="is-active"></span>
    <span></span>
    <span></span>
    <span></span>
  </div>
</section>

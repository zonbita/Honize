<aside class="vx-cart-drawer" id="vx-cart-drawer" aria-label="Giỏ hàng" hidden>
  <div class="vx-cart-drawer-head">
    <strong>Giỏ hàng</strong>
    <button type="button" class="vx-cart-close" id="vx-cart-close" aria-label="Đóng giỏ hàng">×</button>
  </div>
  <div class="vx-cart-drawer-body" id="vx-cart-body">
    <p class="vx-cart-empty">Chưa có sản phẩm nào.</p>
  </div>
  <div class="vx-cart-drawer-foot">
    <p class="vx-cart-total">Tạm tính: <strong id="vx-cart-total">0 ₫</strong></p>
    <a href="#contact" class="vx-btn vx-btn-primary vx-btn-block">Thanh toán</a>
  </div>
</aside>
<div class="vx-cart-backdrop" id="vx-cart-backdrop" hidden></div>
<div class="vx-toast" id="vx-toast" hidden role="status" aria-live="polite"></div>

<header class="vx-header" id="vx-header">
  <div class="vx-header-top">
    <div class="vx-wrap vx-header-top-inner">
      <button type="button" class="vx-menu-toggle" id="vx-menu-toggle" aria-expanded="false" aria-controls="vx-mobile-nav">
        <span></span><span></span><span></span>
        <span class="sr-only">Mở menu</span>
      </button>

      <a href="{{voltixBase}}" class="vx-logo" aria-label="VOLTIX — Trang chủ">
        <span class="vx-logo-text">VOLTIX</span>
      </a>

      <div class="vx-category-dropdown-wrap vx-desktop-only">
        <button type="button" class="vx-category-btn" id="vx-category-btn" aria-expanded="false" aria-controls="vx-category-dropdown" aria-haspopup="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/>
          </svg>
          <span>Danh mục</span>
          <svg class="vx-category-btn-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="vx-category-dropdown" id="vx-category-dropdown" hidden>
          {{> demo/voltix/category-menu-list }}
        </div>
      </div>

      <form class="vx-search vx-desktop-only" role="search" aria-label="Tìm kiếm sản phẩm" id="vx-search-form">
        <label class="sr-only" for="vx-search-input">Tìm kiếm sản phẩm</label>
        <input type="search" id="vx-search-input" placeholder="Tìm kiếm sản phẩm công nghệ…" autocomplete="off" />
        <button type="submit" class="vx-search-btn" aria-label="Tìm kiếm">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/><path d="M20 20l-3-3"/>
          </svg>
        </button>
      </form>

      <div class="vx-header-actions">
        <button type="button" class="vx-search-icon vx-mobile-only" id="vx-search-toggle" aria-label="Tìm kiếm" aria-expanded="false" aria-controls="vx-mobile-search">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/><path d="M20 20l-3-3"/>
          </svg>
        </button>

        <a href="#contact" class="vx-action-link vx-desktop-only">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/><path d="M6 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
          </svg>
          <span>Tài khoản</span>
        </a>

        <button type="button" class="vx-action-link vx-cart-trigger" id="vx-cart-btn" aria-label="Giỏ hàng" aria-expanded="false" aria-controls="vx-cart-drawer">
          <span class="vx-cart-icon-wrap">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M6 7h15l-1.5 9H8L6 7z"/><path d="M6 7L5 3H2"/><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/>
            </svg>
            <span class="vx-cart-badge" id="vx-cart-count">0</span>
          </span>
          <span class="vx-desktop-only">Giỏ hàng</span>
        </button>
      </div>
    </div>
  </div>

  <form class="vx-mobile-search vx-mobile-only" id="vx-mobile-search" role="search" hidden>
    <label class="sr-only" for="vx-mobile-search-input">Tìm kiếm sản phẩm</label>
    <input type="search" id="vx-mobile-search-input" placeholder="Tìm kiếm sản phẩm…" autocomplete="off" />
    <button type="submit" class="vx-search-btn" aria-label="Tìm kiếm">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/><path d="M20 20l-3-3"/>
      </svg>
    </button>
  </form>
</header>
<div class="vx-category-backdrop" id="vx-category-backdrop" hidden></div>

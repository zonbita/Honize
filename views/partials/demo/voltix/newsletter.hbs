<section class="vx-newsletter" id="newsletter" aria-labelledby="vx-newsletter-title">
  <div class="vx-wrap vx-newsletter-inner">
    <div class="vx-newsletter-copy">
      <img
        class="vx-newsletter-envelope"
        src="/images/Demo/DienTu/newsletter-envelope.png"
        alt=""
        width="80"
        height="80"
        loading="lazy"
        aria-hidden="true"
      />
      <div>
        <h2 id="vx-newsletter-title" class="vx-newsletter-title">Nhận ưu đãi độc quyền</h2>
        <p class="vx-newsletter-desc">Đăng ký email để nhận mã giảm giá và cập nhật sản phẩm mới nhất từ VOLTIX.</p>
      </div>
    </div>
    <form class="vx-newsletter-form" id="vx-newsletter-form" action="#" method="post" novalidate>
      <label class="sr-only" for="vx-newsletter-email">Email của bạn</label>
      <input type="email" id="vx-newsletter-email" name="email" placeholder="Nhập email của bạn" required autocomplete="email" />
      <button type="submit" class="vx-btn vx-btn-primary">Đăng ký</button>
      <p class="vx-form-msg" id="vx-newsletter-msg" hidden role="status"></p>
    </form>
  </div>
</section>

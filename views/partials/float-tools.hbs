{{!-- Floating: Back to top + AI chat --}}
<div class="float-tools" id="float-tools">
  <div class="ai-chat-popup" id="ai-chat-popup" role="dialog" aria-label="Chat AI tư vấn" aria-hidden="true">
    <div class="ai-chat-header">
      <div class="ai-chat-header-info">
        <span class="ai-chat-avatar" aria-hidden="true">AI</span>
        <div>
          <p class="ai-chat-title">Honize AI</p>
          <p class="ai-chat-status">Tư vấn thiết kế web · Online</p>
        </div>
      </div>
      <button type="button" class="ai-chat-close" id="btn-ai-close" aria-label="Đóng chat">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <div class="ai-chat-messages" id="ai-chat-messages">
      <div class="ai-msg ai-msg-bot">
        Xin chào! Tôi là trợ lý AI của {{brand}}. Bạn cần tư vấn thiết kế website, báo giá hay tối ưu tốc độ?
      </div>
    </div>

    <form class="ai-chat-form" id="ai-chat-form">
      <input
        type="text"
        id="ai-chat-input"
        class="ai-chat-input"
        placeholder="Nhập câu hỏi..."
        autocomplete="off"
        maxlength="500"
      />
      <button type="submit" class="ai-chat-send" aria-label="Gửi">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
      </button>
    </form>
  </div>

  <button type="button" class="float-btn float-btn-top" id="btn-back-top" aria-label="Lên đầu trang" title="Lên đầu trang">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
    </svg>
    <span>TOP</span>
  </button>

  <button type="button" class="float-btn float-btn-chat" id="btn-ai-chat" aria-label="Chat AI" title="Chat với AI" aria-expanded="false" aria-controls="ai-chat-popup">
    <svg class="float-chat-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
    </svg>
    <svg class="float-close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
</div>

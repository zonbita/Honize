<article class="blog-card{{#if featured}} blog-card-featured{{/if}}">
  {{#if featured}}
  <span class="blog-card-ribbon" aria-label="Nổi bật">NỔI BẬT</span>
  {{/if}}
  <a href="/blog/{{this.slug}}" class="blog-card-media">
    {{#if this.thumbnail}}
    <img src="{{this.thumbnail}}" alt="{{this.title}}" class="blog-card-image" loading="lazy" />
    {{else}}
    <div class="blog-card-image blog-card-image-placeholder">
      <svg class="h-12 w-12 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
    </div>
    {{/if}}
  </a>
  <div class="blog-card-body">
    <h3 class="blog-card-title">
      <a href="/blog/{{this.slug}}">{{this.title}}</a>
    </h3>
    {{#if this.dateLabel}}
    <time class="blog-card-date" datetime="{{this.dateLabel}}">
      <svg class="blog-card-date-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      {{this.dateLabel}}
    </time>
    {{/if}}
    <p class="blog-card-excerpt">{{this.excerpt}}</p>
    <a href="/blog/{{this.slug}}" class="blog-card-link">Xem chi tiết →</a>
  </div>
</article>

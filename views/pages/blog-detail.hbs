<section class="section-padding bg-surface-muted">
  <div class="container-main">
    <a href="/blog" class="mb-6 inline-flex items-center text-sm text-brand-300 hover:text-brand-200">← Bản tin chuyên ngành</a>

    <article class="mx-auto max-w-4xl rounded-2xl border border-slate-100 bg-white p-8 shadow-card md:p-12">
      <header class="border-b border-slate-100 pb-8">
        <h1 class="text-3xl font-extrabold leading-tight text-slate-900 md:text-4xl">{{article.title}}</h1>
        {{#if dateLabel}}
        <p class="mt-3 text-sm text-slate-400">
          <time {{#if dateIso}}datetime="{{dateIso}}"{{/if}}>{{dateLabel}}</time>
          {{#if viewsLabel}} · {{viewsLabel}} lượt xem{{/if}}
        </p>
        {{/if}}
      </header>

      {{#if article.thumbnail}}
      <figure class="mt-8">
        <img src="{{article.thumbnail}}" alt="{{article.title}}" class="w-full rounded-xl object-cover" />
      </figure>
      {{/if}}

      {{#if contentHtml}}
      <div class="article-body mt-10 text-slate-700">{{{contentHtml}}}</div>
      {{else}}
      <p class="mt-10 text-slate-500">Nội dung bài viết đang được cập nhật.</p>
      {{/if}}
    </article>
  </div>
</section>

<section class="section-padding bg-white">
  <div class="container-main">
    <a href="/" class="mb-6 inline-flex items-center text-sm text-brand-600 hover:text-brand-700">← Về trang chủ</a>

    <article class="mx-auto max-w-3xl">
      <div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-slate-500">
        <span class="dash-badge bg-blue-100 text-blue-700">{{article.category}}</span>
        <span>{{article.author}}</span>
        {{#if formattedDate}}<span>{{formattedDate}}</span>{{/if}}
      </div>

      <h1 class="text-3xl font-bold text-slate-900 md:text-4xl">{{article.title}}</h1>

      {{#if article.excerpt}}
      <p class="mt-4 text-lg text-slate-600">{{article.excerpt}}</p>
      {{/if}}

      {{#if article.thumbnail}}
      <img src="{{article.thumbnail}}" alt="{{article.title}}" class="mt-8 w-full rounded-2xl object-cover shadow-card" />
      {{/if}}

      {{#if contentIsHtml}}
      <div class="article-body prose-content mt-8 text-slate-700 leading-relaxed">{{{content}}}</div>
      {{else}}
      <div class="prose-content mt-8 whitespace-pre-wrap text-slate-700 leading-relaxed">{{content}}</div>
      {{/if}}
    </article>
  </div>
</section>

<section class="page-hero page-hero-compact premium-ivory">
  <div class="premium-ivory-decor" aria-hidden="true">
    <svg class="premium-ivory-curve premium-ivory-curve-tl" viewBox="0 0 400 400" fill="none">
      <path d="M40 320 C 80 180, 200 80, 380 60" stroke="currentColor" stroke-width="1.25" />
    </svg>
  </div>
  <div class="container-main relative z-10 text-center">
    <h1 class="section-title">Quy trình thiết kế website</h1>
    <nav class="page-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Trang chủ</a>
      <span class="page-breadcrumb-sep" aria-hidden="true">/</span>
      <span aria-current="page">Quy trình thiết kế website</span>
    </nav>
  </div>
</section>

<section class="process-section section-padding pt-0">
  <div class="container-main max-w-4xl">
    <div class="process-intro text-center" data-aos="fade-up">
      <h2 class="process-intro-title">
        <span class="text-gold">6 bước tiến hành</span><br />
        thiết kế web chuyên nghiệp
      </h2>
      <p class="process-intro-text">
        Để quý khách dễ dàng hình dung về cách tiếp cận một dự án xây dựng website, vui lòng tham khảo quy trình mẫu dưới đây.
      </p>
      <p class="process-intro-text">
        Trong vòng 24 giờ sau khi nhận được bản câu hỏi từ quý khách, {{brand}} sẽ có trả lời chính thức cho quý khách thời gian biểu các bước tiếp theo của dự án.
      </p>
      <a href="#process-steps" class="btn-primary mt-8">Xem chi tiết</a>
    </div>

    <ol class="process-steps" id="process-steps">
      {{#each designProcessSteps}}
      <li class="process-step" data-aos="fade-up" data-aos-delay="{{multiply @index 80}}">
        <div class="process-step-marker">
          <span class="process-step-label">Bước {{this.step}}</span>
        </div>
        <article class="process-step-body">
          <h3 class="process-step-title">{{this.title}}</h3>
          {{#each this.paragraphs}}
          <p class="process-step-text">{{this}}</p>
          {{/each}}
          {{#if this.quote}}
          <blockquote class="process-step-quote">
            <p>{{this.quote}}</p>
            {{#if this.link}}
            <a href="{{this.link.href}}" class="process-step-link">{{this.link.label}}</a>
            {{/if}}
          </blockquote>
          {{else}}
          {{#if this.link}}
          <a href="{{this.link.href}}" class="process-step-link">{{this.link.label}}</a>
          {{/if}}
          {{/if}}
        </article>
      </li>
      {{/each}}
    </ol>

    <div class="process-cta text-center" data-aos="fade-up">
      <p class="text-base leading-relaxed text-slate-600 md:text-lg">{{footerDescription}}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/#banggia" class="btn-primary">Báo giá thiết kế</a>
        <a href="/#contact" class="btn-outline-gold">Liên hệ tư vấn</a>
      </div>
    </div>
  </div>
</section>

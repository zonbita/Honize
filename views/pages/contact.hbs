<section class="contact-page about-section">
  <div class="container-main">
    <div class="contact-page-grid">
      <div class="contact-form-panel" data-aos="fade-up">
        <h2 class="contact-panel-title">Gửi yêu cầu tư vấn</h2>
        <p class="contact-panel-desc">
          Điền đầy đủ thông tin bên dưới — chúng tôi sẽ phản hồi trong vòng 24 giờ làm việc.
        </p>

        {{#if contactSuccess}}
        <div class="contact-alert contact-alert-success" role="status">
          Cảm ơn quý khách! Thông tin đã được ghi nhận. Chúng tôi sẽ liên hệ sớm nhất.
        </div>
        {{/if}}

        {{#if contactError}}
        <div class="contact-alert contact-alert-error" role="alert">
          Vui lòng điền đầy đủ và đúng các trường bắt buộc trước khi gửi.
        </div>
        {{/if}}

        <form class="contact-form" action="/lien-he" method="post">
          <div class="contact-form-row">
            <label class="contact-label" for="contact-name">Họ và tên <span aria-hidden="true">*</span></label>
            <input
              id="contact-name"
              name="name"
              type="text"
              class="contact-input{{#if fieldErrors.name}} contact-input-invalid{{/if}}"
              placeholder="Nguyễn Văn A"
              value="{{formValues.name}}"
              required
              minlength="2"
              maxlength="120"
              autocomplete="name"
            />
            {{#if fieldErrors.name}}
            <p class="contact-field-error">{{fieldErrors.name}}</p>
            {{/if}}
          </div>

          <div class="contact-form-grid2">
            <div class="contact-form-row">
              <label class="contact-label" for="contact-email">Email <span aria-hidden="true">*</span></label>
              <input
                id="contact-email"
                name="email"
                type="email"
                class="contact-input{{#if fieldErrors.email}} contact-input-invalid{{/if}}"
                placeholder="email@congty.vn"
                value="{{formValues.email}}"
                required
                maxlength="160"
                autocomplete="email"
              />
              {{#if fieldErrors.email}}
              <p class="contact-field-error">{{fieldErrors.email}}</p>
              {{/if}}
            </div>
            <div class="contact-form-row">
              <label class="contact-label" for="contact-phone">Điện thoại <span aria-hidden="true">*</span></label>
              <input
                id="contact-phone"
                name="phone"
                type="tel"
                class="contact-input{{#if fieldErrors.phone}} contact-input-invalid{{/if}}"
                placeholder="0900 000 000"
                value="{{formValues.phone}}"
                required
                minlength="8"
                maxlength="40"
                autocomplete="tel"
              />
              {{#if fieldErrors.phone}}
              <p class="contact-field-error">{{fieldErrors.phone}}</p>
              {{/if}}
            </div>
          </div>

          <div class="contact-form-row">
            <label class="contact-label" for="contact-subject">Chủ đề <span aria-hidden="true">*</span></label>
            <input
              id="contact-subject"
              name="subject"
              type="text"
              class="contact-input{{#if fieldErrors.subject}} contact-input-invalid{{/if}}"
              placeholder="Báo giá thiết kế website / Tối ưu tốc độ…"
              value="{{formValues.subject}}"
              required
              maxlength="200"
              autocomplete="off"
            />
            {{#if fieldErrors.subject}}
            <p class="contact-field-error">{{fieldErrors.subject}}</p>
            {{/if}}
          </div>

          <div class="contact-form-row">
            <label class="contact-label" for="contact-message">Nội dung <span aria-hidden="true">*</span></label>
            <textarea
              id="contact-message"
              name="message"
              class="contact-input contact-textarea{{#if fieldErrors.message}} contact-input-invalid{{/if}}"
              rows="6"
              placeholder="Mô tả ngắn nhu cầu của quý khách…"
              required
              minlength="10"
              maxlength="4000"
            >{{formValues.message}}</textarea>
            {{#if fieldErrors.message}}
            <p class="contact-field-error">{{fieldErrors.message}}</p>
            {{/if}}
          </div>

          <button type="submit" class="btn-primary contact-submit">Gửi liên hệ</button>
        </form>
      </div>

      <aside class="contact-info-panel" data-aos="fade-up" data-aos-delay="100">
        <h2 class="contact-panel-title">Thông tin liên hệ</h2>

        <ul class="contact-info-list">
          <li class="contact-info-item">
            <div class="contact-info-icon" aria-hidden="true">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="contact-info-label">Địa chỉ</p>
              <p class="contact-info-value">{{address}}</p>
            </div>
          </li>

          <li class="contact-info-item">
            <div class="contact-info-icon" aria-hidden="true">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="contact-info-label">Điện thoại</p>
              <a href="tel:{{phone}}" class="contact-info-value contact-info-link">{{phone}}</a>
            </div>
          </li>

          <li class="contact-info-item">
            <div class="contact-info-icon" aria-hidden="true">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="contact-info-label">Email</p>
              <a href="mailto:{{email}}" class="contact-info-value contact-info-link">{{email}}</a>
            </div>
          </li>

          {{#if zalo}}
          <li class="contact-info-item">
            <div class="contact-info-icon" aria-hidden="true">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
            </div>
            <div>
              <p class="contact-info-label">Zalo</p>
              <p class="contact-info-value">{{zalo}}</p>
            </div>
          </li>
          {{/if}}

          {{#if skype}}
          <li class="contact-info-item">
            <div class="contact-info-icon" aria-hidden="true">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="contact-info-label">Skype</p>
              <p class="contact-info-value">{{skype}}</p>
            </div>
          </li>
          {{/if}}
        </ul>

        <p class="contact-info-note">{{footerDescription}}</p>
      </aside>
    </div>
  </div>
</section>

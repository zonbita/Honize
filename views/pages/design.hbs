<section class="page-hero page-hero-compact premium-ivory">
  <div class="premium-ivory-decor" aria-hidden="true">
    <svg class="premium-ivory-curve premium-ivory-curve-tl" viewBox="0 0 400 400" fill="none">
      <path d="M40 320 C 80 180, 200 80, 380 60" stroke="currentColor" stroke-width="1.25" />
    </svg>
  </div>
  <div class="container-main relative z-10 text-center">
    <h1 class="section-title">Tăng tốc và tối ưu website</h1>
    <nav class="page-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Trang chủ</a>
      <span class="page-breadcrumb-sep" aria-hidden="true">/</span>
      <span aria-current="page">Tăng tốc và tối ưu website</span>
    </nav>
  </div>
</section>

<section class="optimize-page-intro about-section pt-0">
  <div class="container-main max-w-4xl">
    <div class="text-center" data-aos="fade-up">
      <h2 class="about-section-title">{{optimizePage.introTitle}}</h2>
      {{#each optimizePage.introParagraphs}}
      <p class="about-body-text">{{this}}</p>
      {{/each}}
    </div>
  </div>
</section>

<section class="optimize-section optimize-page-highlights section-padding pt-0">
  <div class="optimize-decor" aria-hidden="true">
    <svg class="optimize-curve optimize-curve-1" viewBox="0 0 400 400" fill="none">
      <path d="M40 320 C 80 180, 200 80, 380 60" stroke="currentColor" stroke-width="1.25" />
    </svg>
    <svg class="optimize-curve optimize-curve-2" viewBox="0 0 400 400" fill="none">
      <path d="M20 40 C 120 120, 220 260, 300 380" stroke="currentColor" stroke-width="1.25" />
    </svg>
  </div>
  <div class="container-main relative z-10">
    <div class="optimize-cards optimize-page-cards">
      <article class="optimize-card" data-aos="fade-up" data-aos-delay="80">
        <div class="optimize-card-icon" aria-hidden="true">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h3 class="optimize-card-title">Mobile Speed</h3>
          <p class="optimize-card-text">
            Cải thiện tốc độ trang web và tăng điểm PageSpeed Insights từ 80 điểm trở lên, giúp giảm tỷ lệ thoát trên trang đáng kể. 99% khách hàng cho biết họ sẽ không quay lại trang web có hiệu suất kém.
          </p>
        </div>
      </article>
      <article class="optimize-card" data-aos="fade-up" data-aos-delay="180">
        <div class="optimize-card-icon" aria-hidden="true">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h3 class="optimize-card-title">Desktop Speed</h3>
          <p class="optimize-card-text">
            Tăng điểm PageSpeed Insights từ 90 điểm trở lên. Google thích các trang web load nhanh — trang web của bạn càng nhanh, thứ hạng SEO càng tốt.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<section class="optimize-packages-section about-section bg-surface-muted">
  <div class="container-main">
    <h2 class="about-section-title text-center" data-aos="fade-up">{{optimizePage.packagesTitle}}</h2>
    <div class="optimize-packages-grid">
      {{#each optimizePage.packages}}
      <article class="opt-pack-card{{#if this.featured}} opt-pack-card-featured{{/if}}" data-aos="fade-up" data-aos-delay="{{multiply @index 100}}">
        <div class="opt-pack-head">
          <h3 class="opt-pack-name">{{this.name}}</h3>
          <p class="opt-pack-price">{{this.price}}</p>
        </div>
        {{#if this.includesNote}}
        <p class="opt-pack-includes">{{this.includesNote}}</p>
        {{/if}}
        <ul class="opt-pack-features">
          {{#each this.features}}
          <li class="opt-pack-feature">
            <span class="opt-pack-check" aria-hidden="true">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
            </span>
            <span>{{this}}</span>
          </li>
          {{/each}}
        </ul>
        <a href="/#contact" class="btn-primary opt-pack-btn">Đăng ký</a>
      </article>
      {{/each}}
    </div>
    <p class="optimize-promo-note text-center" data-aos="fade-up">
      <strong>{{optimizePage.promoNote}}</strong>
    </p>
  </div>
</section>

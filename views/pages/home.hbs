{{!-- Hero Section --}}
<section class="hero-section relative overflow-hidden">
  <div class="hero-section-bg" aria-hidden="true"></div>

  <div class="container-main relative z-10">
    <div class="hero-grid">
      <div class="hero-content" data-aos="fade-right" data-aos-duration="900">
        <p class="hero-kicker">{{hero.kicker}}</p>
        <h1 class="hero-title">
          {{hero.title}}
          <span class="text-gold block">{{hero.titleHighlight}}</span>
        </h1>
        <p class="hero-tagline">{{hero.tagline}}</p>
        <p class="hero-desc">
          {{hero.description}}
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href="#banggia" class="btn-primary">
            {{hero.ctaPrimary}}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#contact" class="btn-outline-gold">
            {{hero.ctaSecondary}}
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>

      <div class="hero-mockup" data-aos="fade-left" data-aos-duration="900" data-aos-delay="120">
        <img
          src="/images/hero-mockup.png"
          alt="Giao diện website trên laptop và điện thoại"
          class="hero-mockup-img"
          width="1536"
          height="1024"
          loading="eager"
        />
      </div>
    </div>

    <div class="hero-features" data-aos="fade-up" data-aos-delay="200">
      <div class="hero-feature-item">
        <img src="/images/icon1.png" alt="" class="hero-feature-icon" width="40" height="40" />
        <span>Giá rẻ</span>
      </div>
      <div class="hero-feature-item">
        <img src="/images/icon2.png" alt="" class="hero-feature-icon" width="40" height="40" />
        <span>Chất lượng</span>
      </div>
      <div class="hero-feature-item">
        <img src="/images/icon3.png" alt="" class="hero-feature-icon" width="40" height="40" />
        <span>Tăng lượng khách hàng</span>
      </div>
    </div>
  </div>
</section>

{{!-- Services Section — minimal premium gold --}}
<section id="services" class="services-section section-padding">
  <div class="services-decor" aria-hidden="true">
    <svg class="services-curve services-curve-1" viewBox="0 0 400 400" fill="none">
      <path d="M360 40 C 220 60, 100 160, 40 340" stroke="currentColor" stroke-width="1.25" />
      <path d="M400 80 C 260 90, 140 180, 70 360" stroke="currentColor" stroke-width="0.75" opacity="0.45" />
    </svg>
    <svg class="services-curve services-curve-2" viewBox="0 0 400 400" fill="none">
      <path d="M40 60 C 140 140, 240 280, 320 390" stroke="currentColor" stroke-width="1.25" />
      <path d="M80 30 C 170 120, 270 250, 370 390" stroke="currentColor" stroke-width="0.75" opacity="0.4" />
    </svg>
  </div>

  <div class="container-main relative z-10">
    <div class="services-header text-center" data-aos="fade-up">
      <h2 class="services-title">Dịch Vụ <span class="text-gold">{{brand}}</span></h2>
      <p class="services-subtitle mx-auto">
        Chúng tôi là những chuyên gia đầu ngành trên 15 năm kinh nghiệm thiết kế web. Website của quý khách được hoàn thiện bởi 3 thế mạnh của công ty: thiết kế đồ họa, lập trình và hosting.
      </p>
    </div>

    <div class="services-grid">
      {{#each services}}
      <article class="services-card" data-aos="fade-up" data-aos-delay="{{multiply @index 100}}">
        <div class="services-card-icon" aria-hidden="true">
          {{#ifeq this.icon "web"}}
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          {{/ifeq}}
          {{#ifeq this.icon "app"}}
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          {{/ifeq}}
          {{#ifeq this.icon "ai"}}
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
          </svg>
          {{/ifeq}}
        </div>
        <h3 class="services-card-title">{{this.title}}</h3>
        <p class="services-card-text">{{this.description}}</p>
        <span class="services-card-arrow" aria-hidden="true">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </span>
      </article>
      {{/each}}
    </div>
  </div>
</section>

{{!-- Speed Optimization Section — minimal premium gold --}}
<section id="optimize" class="optimize-section section-padding">
  <div class="optimize-decor" aria-hidden="true">
    <svg class="optimize-curve optimize-curve-1" viewBox="0 0 400 400" fill="none">
      <path d="M40 320 C 80 180, 200 80, 380 60" stroke="currentColor" stroke-width="1.25" />
      <path d="M20 360 C 100 220, 240 120, 400 100" stroke="currentColor" stroke-width="0.75" opacity="0.45" />
    </svg>
    <svg class="optimize-curve optimize-curve-2" viewBox="0 0 400 400" fill="none">
      <path d="M20 40 C 120 120, 220 260, 300 380" stroke="currentColor" stroke-width="1.25" />
      <path d="M60 20 C 160 100, 260 240, 360 380" stroke="currentColor" stroke-width="0.75" opacity="0.4" />
    </svg>
  </div>

  <div class="container-main relative z-10">
    <div class="optimize-grid">
      <div class="optimize-copy" data-aos="fade-right">
        <p class="optimize-label">Hiệu suất</p>
        <h2 class="optimize-title">
          Dịch vụ <span class="text-gold">Tối Ưu &amp; Tăng Tốc</span> Website
        </h2>
        <p class="optimize-desc">
          Tăng tốc độ tải trang, giảm tỷ lệ thoát và nâng điểm PageSpeed — giúp website mượt mà hơn trên mọi thiết bị và thân thiện hơn với SEO.
        </p>
      </div>

      <div class="optimize-cards">
        <article class="optimize-card" data-aos="fade-up" data-aos-delay="80">
          <div class="optimize-card-icon" aria-hidden="true">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="optimize-card-title">Mobile Speed</h3>
            <p class="optimize-card-text">
              Cải thiện tốc độ trang web và tăng điểm PageSpeed Insights từ 80 điểm trở lên, giúp giảm tỷ lệ thoát trên trang đáng kể. 99% khách hàng cho biết họ sẽ không quay lại trang web có hiệu suất kém.
            </p>
          </div>
        </article>

        <article class="optimize-card" data-aos="fade-up" data-aos-delay="180">
          <div class="optimize-card-icon" aria-hidden="true">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="optimize-card-title">Desktop Speed</h3>
            <p class="optimize-card-text">
              Tăng điểm PageSpeed Insights từ 90 điểm trở lên. Google thích các trang web load nhanh — trang web của bạn càng nhanh, thứ hạng SEO càng tốt.
            </p>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

{{!-- Experience / Responsive — premium champagne gold --}}

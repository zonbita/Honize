{{!-- Projects — grid showcase --}}
<section id="projects" class="project-showcase section-padding scroll-mt-24">
  <div class="container-main text-center">
    <h2 class="section-title">1000+ Dự án tiêu biểu từ {{brand}}</h2>
    <p class="section-subtitle mx-auto">
      Dưới đây là những dự án thiết kế website trọn gói từ quy mô nhỏ đến lớn, giúp khách hàng nâng tầm thương hiệu và tiếp cận khách hàng tiềm năng trên thị trường trực tuyến.
    </p>
  </div>

  <div class="container-main mt-12">
    <div class="project-grid" id="project-grid">
      {{#each projects}}
      <article class="project-card" data-category="{{this.categorySlug}}">
        <a href="{{this.url}}" class="project-card-link">
          <div class="project-card-frame">
            <img src="{{this.image}}" alt="{{this.title}}" width="400" height="500" loading="lazy" draggable="false" />
          </div>
          <p class="project-card-label">{{this.categoryName}}</p>
        </a>
      </article>
      {{/each}}
    </div>

    <div class="mt-12 text-center">
      <button type="button" id="project-load-more" class="btn-primary">Xem thêm mẫu demo</button>
    </div>
  </div>
</section>

<script src="/js/project-grid.js"></script>

{{!-- Legacy anchor --}}
<section id="pricing" class="sr-only" aria-hidden="true"></section>


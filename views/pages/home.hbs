{{!-- Projects — grid showcase --}}
<section id="projects" class="project-showcase premium-ivory section-padding scroll-mt-24">
  <div class="premium-ivory-decor" aria-hidden="true">
    <svg class="premium-ivory-curve premium-ivory-curve-tl" viewBox="0 0 400 400" fill="none">
      <path d="M40 320 C 80 180, 200 80, 380 60" stroke="currentColor" stroke-width="1.25" />
      <path d="M20 360 C 100 220, 240 120, 400 100" stroke="currentColor" stroke-width="0.75" opacity="0.45" />
    </svg>
    <svg class="premium-ivory-curve premium-ivory-curve-br" viewBox="0 0 400 400" fill="none">
      <path d="M20 40 C 120 120, 220 260, 300 380" stroke="currentColor" stroke-width="1.25" />
      <path d="M60 20 C 160 100, 260 240, 360 380" stroke="currentColor" stroke-width="0.75" opacity="0.4" />
    </svg>
  </div>
  <div class="container-main relative z-10 text-center" data-aos="fade-up">
    <h2 class="section-title">1000+ Dự án tiêu biểu từ {{brand}}</h2>
    <p class="section-subtitle mx-auto">
      Dưới đây là những dự án thiết kế website trọn gói từ quy mô nhỏ đến lớn, giúp khách hàng nâng tầm thương hiệu và tiếp cận khách hàng tiềm năng trên thị trường trực tuyến.
    </p>
  </div>

  <div class="container-main relative z-10 mt-12">
    <div class="project-grid" id="project-grid">
      {{#each projects}}
      <article class="project-card" data-category="{{this.categorySlug}}" data-aos="fade-up" data-aos-delay="{{multiply @index 60}}">
        <a href="{{this.url}}" class="project-card-link">
          <div class="project-card-frame">
            <img src="{{this.image}}" alt="{{this.title}}" width="400" height="500" loading="lazy" draggable="false" />
          </div>
          <p class="project-card-label">{{this.categoryName}}</p>
        </a>
      </article>
      {{/each}}
    </div>

    <div class="mt-12 text-center">
      <button type="button" id="project-load-more" class="btn-primary">Xem thêm mẫu demo</button>
    </div>
  </div>
</section>

<script src="/js/project-grid.js"></script>

{{!-- Legacy anchor --}}
<section id="pricing" class="sr-only" aria-hidden="true"></section>

{{!-- Blog Section --}}
<section id="blog" class="section-padding">
  <div class="container-main">
    <div class="blog-section-head" data-aos="fade-up">
      <div class="blog-section-copy">
        <h2 class="blog-section-title">Bản tin chuyên ngành</h2>
        <span class="blog-section-accent" aria-hidden="true"></span>
        <p class="blog-section-desc">Cập nhật kiến thức mới nhất về thiết kế web, SEO và công nghệ.</p>
      </div>
      <a href="/blog" class="blog-section-all">Xem tất cả →</a>
    </div>

    <div class="blog-section-grid">
      {{#each blogPosts}}
      {{#if @first}}
      {{> blog-card featured=true }}
      {{else}}
      {{> blog-card }}
      {{/if}}
      {{/each}}
    </div>
  </div>
</section>

{{!-- Projects — WonderPlugin-style 3D carousel (Swiper Coverflow) --}}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<section id="projects" class="project-showcase section-padding scroll-mt-24">
  <div class="container-main text-center">
    <h2 class="section-title">1000+ Dự án tiêu biểu từ {{brand}}</h2>
    <p class="section-subtitle mx-auto">
      Dưới đây là những dự án thiết kế website trọn gói từ quy mô nhỏ đến lớn, giúp khách hàng nâng tầm thương hiệu và tiếp cận khách hàng tiềm năng trên thị trường trực tuyến.
    </p>
  </div>

  <div class="swiper project-swiper mx-auto mt-10 max-w-[1500px] px-4">
    <div class="swiper-wrapper">
      {{#each projects}}
      <div class="swiper-slide" data-category="{{this.categorySlug}}">
        <a href="{{this.url}}" class="project-slide-link">
          <div class="project-slide-frame">
            <img src="{{this.image}}" alt="{{this.title}}" loading="lazy" draggable="false" />
          </div>
          <p class="project-slide-title">{{this.title}}</p>
        </a>
      </div>
      {{/each}}
    </div>
    <div class="swiper-pagination project-swiper-pagination"></div>
  </div>

  <div class="container-main">
    <div class="mt-8 flex flex-wrap justify-center gap-3" id="project-filters">
      <button type="button" class="project-pill project-pill-active" data-filter="all">Tất cả</button>
      {{#each projectCategories}}
      <button type="button" class="project-pill" data-filter="{{this.slug}}">{{this.name}}</button>
      {{/each}}
    </div>
    <div class="mt-8 text-center">
      <a href="#contact" class="btn-primary">Xem thêm mẫu demo</a>
    </div>
  </div>
</section>


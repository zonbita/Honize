{{!-- Hero Section --}}
<section class="relative overflow-hidden text-white">
  <div class="absolute inset-0 bg-[url('/images/bg-tech.png')] bg-cover bg-center bg-no-repeat"></div>
  <div class="absolute inset-0 bg-brand-950/30"></div>

  <div class="container-main relative section-padding">
    <div class="mx-auto max-w-4xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-brand-200">Dịch vụ</p>
      <h1 class="text-4xl font-extrabold leading-tight md:text-5xl lg:text-6xl">
        <span class="block">Thiết kế website</span>
        <span class="mt-2 block bg-gradient-to-r from-white to-brand-200 bg-clip-text text-transparent">chuyên nghiệp</span>
      </h1>
      <p class="mt-4 text-xl font-medium text-brand-100">mở rộng cơ hội kinh doanh</p>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-brand-100/90">
        {{brand}} sẽ sát cánh cùng quý khách xây dựng website nhằm nâng cao chất lượng dịch vụ và tăng cơ hội quảng bá, bán hàng. Hãy liên hệ để trải nghiệm sự am hiểu, nhiệt tình, sáng tạo và chuyên nghiệp của chúng tôi.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="#pricing" class="btn-primary bg-white !text-brand-700 shadow-white/20 hover:!bg-brand-50">Báo Giá</a>
        <a href="#contact" class="btn-outline">Liên Hệ Ngay</a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 60L60 50C120 40 240 20 360 15C480 10 600 20 720 25C840 30 960 30 1080 25C1200 20 1320 10 1380 5L1440 0V60H0Z" fill="#f8fafc"/>
    </svg>
  </div>
</section>

{{!-- Services Section --}}
<section id="services" class="section-padding bg-surface-muted">
  <div class="container-main">
    <div class="text-center">
      <h2 class="section-title">Dịch Vụ <span class="text-brand-600">{{brand}}</span></h2>
      <p class="section-subtitle mx-auto">
        Chúng tôi là những chuyên gia đầu ngành trên 15 năm kinh nghiệm thiết kế web. Website của quý khách được hoàn thiện bởi 3 thế mạnh của công ty: thiết kế đồ họa, lập trình và hosting.
      </p>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {{#each services}}
      <div class="card-service">
        <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-50 text-brand-600">
          {{#if (eq this.icon "design")}}
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          {{else if (eq this.icon "maintenance")}}
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          {{else}}
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>
          {{/if}}
        </div>
        <h3 class="text-xl font-bold text-slate-900">{{this.title}}</h3>
        <p class="mt-3 text-sm leading-relaxed text-slate-600">{{this.description}}</p>
      </div>
      {{/each}}
    </div>
  </div>
</section>

{{!-- Projects Section --}}
<section id="projects" class="section-padding bg-white">
  <div class="container-main">
    <div class="text-center">
      <h2 class="section-title">Dự Án Tiêu Biểu</h2>
      <p class="section-subtitle mx-auto">
        Quý khách tham khảo một số dự án thiết kế web đã thực hiện trong các lĩnh vực khác nhau để có cái nhìn khách quan hơn về năng lực của chúng tôi.
      </p>
    </div>

    <div class="mt-12 flex flex-wrap justify-center gap-3">
      {{#each projectCategories}}
      <a href="/projects/{{this.slug}}" class="project-pill">{{this.name}}</a>
      {{/each}}
    </div>
  </div>
</section>

{{!-- Speed Optimization Section --}}
<section id="optimize" class="section-padding bg-section-gradient">
  <div class="container-main">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-600">Hiệu suất</p>
        <h2 class="section-title mt-2">
          Dịch vụ <span class="text-brand-600">Tối Ưu &amp; Tăng Tốc</span> Website
        </h2>
      </div>
      <div class="space-y-6">
        <div class="rounded-2xl bg-white p-6 shadow-card">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-green-100 text-green-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900">Mobile Speed</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">
                Cải thiện tốc độ trang web và tăng điểm PageSpeed Insights từ 80 điểm trở lên, giúp giảm tỷ lệ thoát trên trang đáng kể. 99% khách hàng cho biết họ sẽ không quay lại trang web có hiệu suất kém.
              </p>
            </div>
          </div>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-card">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-blue-100 text-blue-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900">Desktop Speed</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">
                Tăng điểm PageSpeed Insights từ 90 điểm trở lên. Google thích các trang web load nhanh — trang web của bạn càng nhanh, thứ hạng SEO càng tốt.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{{!-- Responsive Section --}}
<section id="about" class="section-padding bg-brand-950 text-white">
  <div class="container-main">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-300">Trải nghiệm</p>
      <h2 class="mt-2 text-3xl font-bold md:text-4xl">
        Lợi ích từ <span class="text-brand-300">Design &amp; Responsive</span> trên mọi thiết bị
      </h2>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-2">
      <div class="rounded-2xl border border-brand-800 bg-brand-900/50 p-8">
        <h3 class="text-lg font-bold text-brand-200">Đối với người dùng</h3>
        <p class="mt-4 text-sm leading-relaxed text-brand-100/80">
          Họ có được những trải nghiệm thú vị hơn khi truy cập website trên các thiết bị khác nhau. Thao tác nhanh hơn, thuận tiện hơn nhờ vào bố cục hợp lý.
        </p>
      </div>
      <div class="rounded-2xl border border-brand-800 bg-brand-900/50 p-8">
        <h3 class="text-lg font-bold text-brand-200">Đối với chủ sở hữu website</h3>
        <p class="mt-4 text-sm leading-relaxed text-brand-100/80">
          Là cách tiếp cận tốt nhất để tăng khách hàng mua sắm sản phẩm của mình. Công nghệ Responsive ngày càng được chú ý đến và phổ biến hơn.
        </p>
      </div>
    </div>
  </div>
</section>

{{!-- Pricing CTA --}}
<section id="pricing" class="section-padding bg-white">
  <div class="container-main text-center">
    <h2 class="section-title">Báo Giá Thiết Kế Website</h2>
    <p class="section-subtitle mx-auto">
      Liên hệ ngay để nhận tư vấn miễn phí và bảng báo giá chi tiết phù hợp với nhu cầu kinh doanh của quý khách.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="tel:{{phone}}" class="btn-primary">{{phone}}</a>
      <a href="mailto:{{email}}" class="inline-flex items-center justify-center rounded-full border-2 border-brand-600 px-8 py-3 text-sm font-semibold text-brand-600 transition-all hover:bg-brand-600 hover:text-white">{{email}}</a>
    </div>
  </div>
</section>

{{!-- Blog Section --}}
<section id="blog" class="section-padding bg-surface-muted">
  <div class="container-main">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h2 class="section-title">Bản tin chuyên ngành</h2>
        <p class="section-subtitle">Cập nhật kiến thức mới nhất về thiết kế web, SEO và công nghệ.</p>
      </div>
      <a href="/blog" class="text-sm font-semibold text-brand-600 hover:text-brand-700">Xem tất cả →</a>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {{#each blogPosts}}
      <article class="blog-card">
        <div class="h-2 bg-gradient-to-r from-brand-500 to-brand-700"></div>
        <div class="flex flex-1 flex-col p-6">
          <h3 class="text-lg font-bold text-slate-900 line-clamp-2">{{this.title}}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600 line-clamp-3">{{this.excerpt}}</p>
          <a href="/blog/{{this.slug}}" class="mt-4 inline-flex items-center text-sm font-semibold text-brand-600 hover:text-brand-700">
            Xem chi tiết
            <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>
      {{/each}}
    </div>
  </div>
</section>

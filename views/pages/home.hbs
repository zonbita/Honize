{{!-- Hero Section --}}
<section class="hero-section relative overflow-hidden">
  <div class="hero-section-bg" aria-hidden="true"></div>

  <div class="container-main relative z-10">
    <div class="hero-grid">
      <div class="hero-content">
        <p class="hero-kicker">Dịch vụ —</p>
        <h1 class="hero-title">
          Thiết kế website
          <span class="text-gold block">chuyên nghiệp</span>
        </h1>
        <p class="hero-tagline">→ mở rộng cơ hội kinh doanh</p>
        <p class="hero-desc">
          {{brand}} sẽ sát cánh cùng quý khách xây dựng website nhằm nâng cao chất lượng dịch vụ và tăng cơ hội quảng bá, bán hàng. Hãy liên hệ để trải nghiệm sự am hiểu, nhiệt tình, sáng tạo và chuyên nghiệp của chúng tôi.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href="#banggia" class="btn-primary">
            Báo Giá
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#contact" class="btn-outline-gold">
            Liên Hệ Ngay
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>

      <div class="hero-mockup">
        <img
          src="/images/hero-mockup.png"
          alt="Giao diện website trên laptop và điện thoại"
          class="hero-mockup-img"
          width="1536"
          height="1024"
          loading="eager"
        />
      </div>
    </div>

    <div class="hero-features">
      <div class="hero-feature-item">
        <img src="/images/icon1.png" alt="" class="hero-feature-icon" width="40" height="40" />
        <span>Giá rẻ</span>
      </div>
      <div class="hero-feature-item">
        <img src="/images/icon2.png" alt="" class="hero-feature-icon" width="40" height="40" />
        <span>Chất lượng</span>
      </div>
      <div class="hero-feature-item">
        <img src="/images/icon3.png" alt="" class="hero-feature-icon" width="40" height="40" />
        <span>Tăng lượng khách hàng</span>
      </div>
    </div>
  </div>
</section>

{{!-- Services Section --}}
<section id="services" class="section-padding bg-white">
  <div class="container-main">
    <div class="text-center">
      <h2 class="section-title">Dịch Vụ <span class="text-gold">{{brand}}</span></h2>
      <p class="section-subtitle mx-auto">
        Chúng tôi là những chuyên gia đầu ngành trên 15 năm kinh nghiệm thiết kế web. Website của quý khách được hoàn thiện bởi 3 thế mạnh của công ty: thiết kế đồ họa, lập trình và hosting.
      </p>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {{#each services}}
      <div class="card-service">
        <img src="{{this.image}}" alt="" class="card-service-icon" width="72" height="72" />
        <h3 class="text-xl font-bold text-slate-900">{{this.title}}</h3>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600">{{this.description}}</p>
        <span class="card-service-arrow" aria-hidden="true">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </span>
      </div>
      {{/each}}
    </div>
  </div>
</section>

{{!-- Speed Optimization Section --}}
<section id="optimize" class="section-padding bg-section-gradient">
  <div class="container-main">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="text-gold text-sm font-semibold uppercase tracking-widest">Hiệu suất</p>
        <h2 class="section-title mt-2">
          Dịch vụ <span class="text-gold">Tối Ưu &amp; Tăng Tốc</span> Website
        </h2>
      </div>
      <div class="space-y-6">
        <div class="rounded-2xl bg-white p-6 shadow-card">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-green-100 text-green-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900">Mobile Speed</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">
                Cải thiện tốc độ trang web và tăng điểm PageSpeed Insights từ 80 điểm trở lên, giúp giảm tỷ lệ thoát trên trang đáng kể. 99% khách hàng cho biết họ sẽ không quay lại trang web có hiệu suất kém.
              </p>
            </div>
          </div>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-card">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-blue-100 text-blue-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900">Desktop Speed</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">
                Tăng điểm PageSpeed Insights từ 90 điểm trở lên. Google thích các trang web load nhanh — trang web của bạn càng nhanh, thứ hạng SEO càng tốt.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{{!-- Responsive Section --}}
<section id="about" class="responsive-section section-padding text-white">
  <div class="responsive-section-bg" aria-hidden="true"></div>
  <div class="container-main relative z-10">
    <div class="text-center">
      <p class="text-gold-on-dark text-sm font-semibold uppercase tracking-widest">Trải nghiệm</p>
      <h2 class="mt-2 text-3xl font-bold md:text-4xl">
        Lợi ích từ <span class="text-gold-on-dark">Design &amp; Responsive</span> trên mọi thiết bị
      </h2>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-2">
      <div class="rounded-2xl border border-brand-800 bg-brand-900/50 p-8">
        <h3 class="text-lg font-bold text-brand-200">Đối với người dùng</h3>
        <p class="mt-4 text-sm leading-relaxed text-brand-100/80">
          Họ có được những trải nghiệm thú vị hơn khi truy cập website trên các thiết bị khác nhau. Thao tác nhanh hơn, thuận tiện hơn nhờ vào bố cục hợp lý.
        </p>
      </div>
      <div class="rounded-2xl border border-brand-800 bg-brand-900/50 p-8">
        <h3 class="text-lg font-bold text-brand-200">Đối với chủ sở hữu website</h3>
        <p class="mt-4 text-sm leading-relaxed text-brand-100/80">
          Là cách tiếp cận tốt nhất để tăng khách hàng mua sắm sản phẩm của mình. Công nghệ Responsive ngày càng được chú ý đến và phổ biến hơn.
        </p>
      </div>
    </div>
  </div>
</section>


<section class="section-padding bg-surface-muted">
  <div class="container-main">
    <div class="mb-12">
      <a href="/" class="mb-4 inline-flex items-center text-sm text-brand-gold hover:opacity-80">← Về trang chủ</a>
      <h1 class="section-title">Bản tin chuyên ngành</h1>
      <p class="section-subtitle">Cập nhật kiến thức mới nhất về thiết kế web, SEO và công nghệ.</p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {{#each blogPosts}}
      {{> blog-card }}
      {{/each}}
    </div>

    {{#unless blogPosts.length}}
    <p class="text-center text-slate-500">Chưa có bài viết nào được xuất bản.</p>
    {{/unless}}
  </div>
</section>

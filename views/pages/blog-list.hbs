<section class="section-padding bg-surface-muted">
  <div class="container-main">
    <div class="mb-12">
      <a href="/" class="mb-4 inline-flex items-center text-sm text-brand-600 hover:text-brand-700">← Về trang chủ</a>
      <h1 class="section-title">Bản tin chuyên ngành</h1>
      <p class="section-subtitle">Cập nhật kiến thức mới nhất về thiết kế web, SEO và công nghệ.</p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {{#each blogPosts}}
      <article class="blog-card">
        <div class="h-2 bg-gradient-to-r from-brand-500 to-brand-700"></div>
        <div class="flex flex-1 flex-col p-6">
          {{#if this.category}}
          <span class="mb-2 text-xs font-medium text-brand-600">{{this.category}}</span>
          {{/if}}
          <h2 class="text-lg font-bold text-slate-900 line-clamp-2">{{this.title}}</h2>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600 line-clamp-3">{{this.excerpt}}</p>
          <a href="/blog/{{this.slug}}" class="mt-4 inline-flex items-center text-sm font-semibold text-brand-600 hover:text-brand-700">
            Xem chi tiết
            <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>
      {{/each}}
    </div>

    {{#unless blogPosts.length}}
    <p class="text-center text-slate-500">Chưa có bài viết nào được xuất bản.</p>
    {{/unless}}
  </div>
</section>

<header class="sticky top-0 z-30 flex h-16 items-center justify-between border-b border-slate-200 bg-white px-6">
  <div>
    <h1 class="text-xl font-bold text-slate-800">{{pageTitle}}</h1>
    <p class="text-xs text-slate-500">Quản lý bài viết, SEO Link và luồng xử lý</p>
  </div>
  <div class="flex items-center gap-3">
    <div class="flex h-9 w-9 items-center justify-center rounded-full bg-blue-500 text-xs font-bold text-white">{{user.avatar}}</div>
    <div class="hidden sm:block">
      <p class="text-sm font-semibold text-slate-800">{{user.name}}</p>
      <p class="text-xs text-slate-400">{{user.role}}</p>
    </div>
  </div>
</header>

<div class="flex-1 overflow-y-auto p-6">
  {{!-- Context Simulator --}}
  <div class="dash-card mb-6 p-5">
    <h2 class="mb-3 text-sm font-bold text-slate-800">Mô phỏng ngữ cảnh (Context)</h2>
    <div class="flex flex-wrap gap-2">
      <a href="/dashboard/behavior-tree?status=draft" class="dash-tab {{#if (eq behaviorContext.articleStatus 'draft')}}dash-tab-active{{/if}}">Bản nháp</a>
      <a href="/dashboard/behavior-tree?status=published" class="dash-tab {{#if (eq behaviorContext.articleStatus 'published')}}dash-tab-active{{/if}}">Đã xuất bản</a>
      <a href="/dashboard/behavior-tree?status=scheduled" class="dash-tab {{#if (eq behaviorContext.articleStatus 'scheduled')}}dash-tab-active{{/if}}">Đã lên lịch</a>
      <a href="/dashboard/behavior-tree?status=draft&seo=1" class="dash-tab">SEO đạt</a>
      <a href="/dashboard/behavior-tree?status=draft&meta=1" class="dash-tab">Meta đầy đủ</a>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 xl:grid-cols-4">
    {{!-- Tree Structure --}}
    <div class="dash-card xl:col-span-3">
      <div class="border-b border-slate-100 bg-gradient-to-r from-blue-600 to-blue-500 px-5 py-4">
        <h2 class="text-lg font-bold text-white">Cấu trúc Behavior Tree</h2>
        <p class="text-xs text-blue-100">Dashboard CMS Root → Selector → Sequence nodes</p>
      </div>
      <div class="space-y-1 p-4">
        {{#each flatNodes}}
        <div class="flex items-start gap-3 rounded-lg px-3 py-2.5 transition-colors hover:bg-slate-50" style="padding-left: {{multiply this.depth 24}}px">
          <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-lg text-xs font-bold
            {{#if (eq this.type 'root')}}bg-slate-800 text-white{{/if}}
            {{#if (eq this.type 'selector')}}bg-teal-100 text-teal-700{{/if}}
            {{#if (eq this.type 'sequence')}}bg-blue-100 text-blue-700{{/if}}
            {{#if (eq this.type 'condition')}}bg-green-100 text-green-700{{/if}}
            {{#if (eq this.type 'action')}}bg-orange-100 text-orange-700{{/if}}
          ">
            {{#if (eq this.type 'selector')}}?{{/if}}
            {{#if (eq this.type 'sequence')}}→{{/if}}
            {{#if (eq this.type 'condition')}}✓{{/if}}
            {{#if (eq this.type 'action')}}⚙{{/if}}
            {{#if (eq this.type 'root')}}R{{/if}}
          </span>
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-sm font-medium text-slate-800">{{this.label}}</span>
              <span class="bt-status bt-status-{{this.status}}">{{this.status}}</span>
            </div>
            {{#if this.message}}
            <p class="mt-0.5 text-xs text-slate-500">{{this.message}}</p>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Legend --}}
    <div class="space-y-4">
      <div class="dash-card p-5">
        <h3 class="mb-3 text-sm font-bold text-slate-800">Cách hoạt động</h3>
        <ul class="space-y-3">
          {{#each legend}}
          <li class="flex gap-2 text-xs">
            <span class="font-bold text-blue-600">{{this.label}}</span>
            <span class="text-slate-500">{{this.desc}}</span>
          </li>
          {{/each}}
        </ul>
      </div>

      <div class="dash-card p-5">
        <h3 class="mb-3 text-sm font-bold text-slate-800">Trạng thái node</h3>
        <ul class="space-y-2">
          {{#each nodeStatuses}}
          <li class="flex items-center gap-2 text-xs">
            <span class="h-3 w-3 rounded-full {{this.color}}"></span>
            <span class="font-medium text-slate-700">{{this.label}}</span>
          </li>
          {{/each}}
        </ul>
      </div>
    </div>
  </div>

  {{!-- Info boxes --}}
  <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-3">
    <div class="dash-card p-5">
      <h3 class="mb-2 text-sm font-bold text-blue-700">Ứng dụng vào dashboard</h3>
      <ul class="space-y-1.5">
        {{#each applications}}
        <li class="flex gap-2 text-xs text-slate-600"><span class="text-blue-500">•</span>{{this}}</li>
        {{/each}}
      </ul>
    </div>
    <div class="dash-card p-5">
      <h3 class="mb-2 text-sm font-bold text-green-700">Ưu điểm</h3>
      <ul class="space-y-1.5">
        {{#each advantages}}
        <li class="flex gap-2 text-xs text-slate-600"><span class="text-green-500">✓</span>{{this}}</li>
        {{/each}}
      </ul>
    </div>
    <div class="dash-card p-5">
      <h3 class="mb-2 text-sm font-bold text-orange-700">Hạn chế</h3>
      <ul class="space-y-1.5">
        {{#each limitations}}
        <li class="flex gap-2 text-xs text-slate-600"><span class="text-orange-500">!</span>{{this}}</li>
        {{/each}}
      </ul>
    </div>
  </div>

  {{!-- Use cases --}}
  <div class="mt-6">
    <h2 class="mb-4 text-lg font-bold text-slate-800">Ví dụ use case</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {{#each useCases}}
      <div class="dash-card p-5">
        <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-blue-50 text-blue-600">
          {{#if (eq this.icon 'document')}}
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          {{else if (eq this.icon 'search')}}
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          {{else if (eq this.icon 'link')}}
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          {{else}}
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          {{/if}}
        </div>
        <h3 class="text-sm font-bold text-slate-800">{{this.title}}</h3>
        <p class="mt-1 text-xs text-slate-500">{{this.desc}}</p>
      </div>
      {{/each}}
    </div>
  </div>
</div>

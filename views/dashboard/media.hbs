{{> dashboard/page-header }}

<div class="flex-1 overflow-y-auto p-6">
  <p class="mb-6 text-sm text-slate-500">
    Thư viện ảnh — hiển thị
    <code class="rounded bg-slate-100 px-1">public/images/Demo/</code>
    và
    <code class="rounded bg-slate-100 px-1">public/uploads/</code>
  </p>

  {{#if deleted}}
  <div class="mb-4 rounded-lg bg-green-50 px-4 py-3 text-sm text-green-700">Đã xóa ảnh thành công.</div>
  {{/if}}

  {{#if mediaFiles}}
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
    {{#each mediaFiles}}
    <div class="dash-card overflow-hidden">
      <img src="{{this.url}}" alt="{{this.name}}" class="h-36 w-full object-cover" />
      <div class="space-y-2 p-3">
        <p class="truncate text-xs font-medium text-slate-700" title="{{this.folder}}/{{this.name}}">{{this.name}}</p>
        <p class="truncate text-[10px] text-slate-400">{{this.folder}}</p>
        <input readonly value="{{this.url}}" class="w-full truncate rounded border border-slate-200 bg-slate-50 px-2 py-1 text-[10px] text-slate-500" onclick="this.select();document.execCommand('copy')" />
        {{#if this.canDelete}}
        <form method="POST" action="/dashboard/media/{{this.name}}/delete" onsubmit="return confirm('Xóa ảnh này?');">
          <button type="submit" class="w-full rounded-lg border border-red-200 px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50">
            Xóa
          </button>
        </form>
        {{else}}
        <p class="text-center text-[10px] text-slate-400">Ảnh demo — không xóa</p>
        {{/if}}
      </div>
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="dash-card flex flex-col items-center justify-center p-12 text-center">
    <svg class="mb-4 h-12 w-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
    <p class="text-slate-500">
      Chưa có file media. Thêm ảnh demo vào
      <code class="rounded bg-slate-100 px-1">public/images/Demo/</code>
      hoặc upload vào
      <code class="rounded bg-slate-100 px-1">public/uploads/</code>
    </p>
  </div>
  {{/if}}
</div>

<header class="sticky top-0 z-30 flex h-16 items-center justify-between border-b border-slate-200 bg-white px-6">
  <div class="flex items-center gap-4">
    <a href="/dashboard" class="text-slate-400 hover:text-slate-600">← Quay lại</a>
    <h1 class="text-xl font-bold text-slate-800">{{pageTitle}}</h1>
  </div>
</header>

<div class="flex-1 overflow-y-auto p-6">
  <form id="article-form" method="POST" action="{{#if isEdit}}/dashboard/articles/{{article.slug}}{{else}}/dashboard/articles{{/if}}" class="mx-auto max-w-5xl space-y-6">
    <div class="dash-card p-6 space-y-4">
      <h2 class="font-bold text-slate-800">Thông tin bài viết</h2>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700">Tiêu đề *</label>
        <input name="title" value="{{article.title}}" required class="dash-input w-full" placeholder="Nhập tiêu đề bài viết" />
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="mb-1 block text-sm font-medium text-slate-700">Slug (URL)</label>
          <input name="slug" value="{{article.slug}}" class="dash-input w-full" placeholder="tu-dong-tao-tu-tieu-de" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-slate-700">Danh mục</label>
          <select name="category" class="dash-input w-full">
            <option {{#if (eq article.category 'Du lịch')}}selected{{/if}}>Du lịch</option>
            <option {{#if (eq article.category 'Công nghệ')}}selected{{/if}}>Công nghệ</option>
            <option {{#if (eq article.category 'Marketing')}}selected{{/if}}>Marketing</option>
            <option {{#if (eq article.category 'Tin tức')}}selected{{/if}}>Tin tức</option>
          </select>
        </div>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700">Mô tả ngắn</label>
        <textarea name="excerpt" rows="2" class="dash-input w-full" placeholder="Tóm tắt bài viết">{{article.excerpt}}</textarea>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="mb-1 block text-sm font-medium text-slate-700">Tác giả</label>
          <input name="author" value="{{article.author}}" class="dash-input w-full" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium text-slate-700">Trạng thái</label>
          <select name="status" class="dash-input w-full">
            <option value="draft" {{#if (eq article.status 'draft')}}selected{{/if}}>Bản nháp</option>
            <option value="published" {{#if (eq article.status 'published')}}selected{{/if}}>Đã xuất bản</option>
            <option value="scheduled" {{#if (eq article.status 'scheduled')}}selected{{/if}}>Đã lên lịch</option>
          </select>
        </div>
      </div>

      <div>
        <label class="mb-2 block text-sm font-medium text-slate-700">Ảnh thumbnail</label>
        <div class="flex flex-wrap items-start gap-4">
          <div id="thumb-preview" class="thumb-preview {{#unless article.thumbnail}}thumb-preview-empty{{/unless}}">
            {{#if article.thumbnail}}
            <img id="thumb-preview-img" src="{{article.thumbnail}}" alt="Thumbnail" class="h-full w-full object-cover" />
            {{else}}
            <img id="thumb-preview-img" src="" alt="" class="hidden h-full w-full object-cover" />
            <svg class="h-8 w-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            {{/if}}
          </div>

          <div class="min-w-[240px] flex-1 space-y-3">
            <div id="thumb-dropzone" class="thumb-dropzone">
              <input type="file" id="thumb-file" accept="image/*" class="hidden" />
              <svg class="mx-auto mb-2 h-8 w-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
              <p class="text-sm font-medium text-slate-700">Kéo thả hình vào đây</p>
              <p class="mt-1 text-xs text-slate-400">
                hoặc
                <button type="button" id="thumb-browse" class="text-brand-600 hover:underline">chọn từ máy</button>
                ·
                <button type="button" id="thumb-library-toggle" class="text-brand-600 hover:underline" aria-expanded="false" aria-controls="thumb-library-modal" aria-haspopup="dialog">chọn từ thư viện</button>
                · JPG, PNG, WebP · tối đa 5MB
              </p>
              <p id="thumb-upload-status" class="mt-2 hidden text-xs"></p>
            </div>
            <div>
              <label class="mb-1 block text-xs text-slate-500">Hoặc dán URL ảnh</label>
              <input id="thumbnail-input" name="thumbnail" value="{{article.thumbnail}}" class="dash-input w-full text-sm" placeholder="https://... hoặc /images/... hoặc /uploads/..." />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="dash-card overflow-hidden p-6 space-y-3">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="font-bold text-slate-800">Nội dung bài viết</h2>
          <p class="text-xs text-slate-500">Trình soạn thảo TinyMCE — lưu HTML vào <code class="rounded bg-slate-100 px-1">{{#if article.slug}}{{article.slug}}{{else}}slug{{/if}}.md</code></p>
        </div>
      </div>
      <textarea id="article-content" name="content" class="w-full">{{article.content}}</textarea>
    </div>

    <div class="dash-card p-6 space-y-4">
      <h2 class="font-bold text-slate-800">SEO</h2>
      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700">Meta title</label>
        <input name="metaTitle" value="{{article.metaTitle}}" class="dash-input w-full" />
      </div>
      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700">Meta description</label>
        <textarea name="metaDescription" rows="2" class="dash-input w-full">{{article.metaDescription}}</textarea>
      </div>
      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700">SEO URL</label>
        <input name="seoUrl" value="{{article.seoUrl}}" class="dash-input w-full" placeholder="/blog/slug-bai-viet" />
      </div>
    </div>

    <div class="flex gap-3">
      <button type="submit" class="dash-btn-primary">{{#if isEdit}}Cập nhật{{else}}Tạo bài viết{{/if}}</button>
      <a href="/dashboard" class="dash-btn-secondary">Hủy</a>
    </div>
  </form>

  {{> dashboard/image-library-picker }}
</div>

<script src="https://cdn.jsdelivr.net/npm/tinymce@7.6.1/tinymce.min.js"></script>
<script>
  tinymce.init({
    selector: '#article-content',
    height: 520,
    menubar: false,
    license_key: 'gpl',
    base_url: 'https://cdn.jsdelivr.net/npm/tinymce@7.6.1',
    suffix: '.min',
    promotion: false,
    branding: false,
    language: 'vi',
    language_url: 'https://cdn.jsdelivr.net/npm/tinymce-i18n@24.12.9/langs7/vi.js',
    plugins: [
      'lists', 'link', 'code', 'autoresize', 'fullscreen', 'wordcount',
      'searchreplace', 'table', 'image', 'media', 'charmap', 'anchor',
    ],
    toolbar: [
      'blocks | alignleft aligncenter alignright alignjustify',
      'bold italic link strikethrough removeformat',
      'code forecolor backcolor superscript subscript underline',
      'bullist numlist outdent indent | blockquote table image media charmap anchor',
      'searchreplace fullscreen',
    ].join(' | '),
    block_formats: 'Đoạn văn=p; Tiêu đề 2=h2; Tiêu đề 3=h3; Tiêu đề 4=h4',
    content_style: 'body { font-family: "Be Vietnam Pro", sans-serif; font-size: 15px; line-height: 1.7; color: #334155; }',
    paste_as_text: false,
    link_default_target: '_blank',
    image_caption: true,
    table_toolbar: 'tableprops tabledelete | tableinsertrowbefore tableinsertrowafter tabledeleterow | tableinsertcolbefore tableinsertcolafter tabledeletecol',
    setup(editor) {
      editor.on('change', () => editor.save());
    },
  });

  document.getElementById('article-form').addEventListener('submit', () => {
    tinymce.triggerSave();
  });

  (function initThumbnailUpload() {
    const dropzone = document.getElementById('thumb-dropzone');
    const fileInput = document.getElementById('thumb-file');
    const browseBtn = document.getElementById('thumb-browse');
    const urlInput = document.getElementById('thumbnail-input');
    const preview = document.getElementById('thumb-preview');
    const previewImg = document.getElementById('thumb-preview-img');
    const status = document.getElementById('thumb-upload-status');

    function setPreview(url) {
      previewImg.src = url;
      previewImg.classList.remove('hidden');
      preview.classList.remove('thumb-preview-empty');
      urlInput.value = url;
    }

    function showStatus(msg, isError) {
      status.textContent = msg;
      status.className = 'mt-2 text-xs ' + (isError ? 'text-red-600' : 'text-green-600');
      status.classList.remove('hidden');
    }

    async function uploadFile(file) {
      if (!file.type.startsWith('image/')) {
        showStatus('Chỉ chấp nhận file hình ảnh', true);
        return;
      }
      if (file.size > 5 * 1024 * 1024) {
        showStatus('File quá lớn (tối đa 5MB)', true);
        return;
      }

      showStatus('Đang tải lên...', false);
      dropzone.classList.add('thumb-dropzone-loading');

      const formData = new FormData();
      formData.append('file', file);

      try {
        const res = await fetch('/api/upload', { method: 'POST', body: formData });
        let data;
        const text = await res.text();
        try {
          data = JSON.parse(text);
        } catch {
          throw new Error(text || 'Upload thất bại');
        }
        if (!res.ok) throw new Error(data.message || 'Upload thất bại');
        setPreview(data.url);
        showStatus('Đã tải lên: ' + data.name, false);
      } catch (err) {
        showStatus(err.message || 'Upload thất bại', true);
      } finally {
        dropzone.classList.remove('thumb-dropzone-loading');
      }
    }

    browseBtn.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => {
      if (fileInput.files[0]) uploadFile(fileInput.files[0]);
    });

    ['dragenter', 'dragover'].forEach((evt) => {
      dropzone.addEventListener(evt, (e) => {
        e.preventDefault();
        dropzone.classList.add('thumb-dropzone-active');
      });
    });
    ['dragleave', 'drop'].forEach((evt) => {
      dropzone.addEventListener(evt, (e) => {
        e.preventDefault();
        dropzone.classList.remove('thumb-dropzone-active');
      });
    });
    dropzone.addEventListener('drop', (e) => {
      const file = e.dataTransfer.files[0];
      if (file) uploadFile(file);
    });

    urlInput.addEventListener('input', () => {
      const url = urlInput.value.trim();
      if (url) setPreview(url);
    });
  })();
</script>

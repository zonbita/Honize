<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{pageTitle}} — NewsHub CMS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css{{#if devMode}}?v={{devRevision}}{{/if}}" />
  {{#if alreadyLoggedIn}}
  <meta http-equiv="refresh" content="0;url={{redirectTo}}" />
  {{/if}}
</head>
<body class="min-h-screen bg-[#f0f2f5] font-sans text-slate-700 antialiased">
  {{#if alreadyLoggedIn}}
  <p class="p-8 text-center text-sm text-slate-500">Đang chuyển hướng...</p>
  {{else}}
  <div class="flex min-h-screen items-center justify-center p-6">
    <div class="w-full max-w-md space-y-5 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">NewsHub CMS</p>
        <h1 class="mt-1 text-2xl font-bold text-slate-800">Đăng nhập</h1>
        <p class="mt-1 text-sm text-slate-500">
          {{#if googleEnabled}}
          Đăng nhập bằng Google{{#if allowedEmail}} (<span class="font-medium text-slate-700">{{allowedEmail}}</span>){{/if}}.
          {{else}}
          Vào quản trị để chỉnh nội dung website.
          {{/if}}
        </p>
      </div>

      {{#if error}}
      <div class="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-600">{{error}}</div>
      {{/if}}

      {{#if googleEnabled}}
      <a
        href="{{googleLoginUrl}}"
        class="flex w-full items-center justify-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm transition hover:bg-slate-50"
      >
        <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
          <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.7 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3 0 5.8 1.1 7.9 3l5.7-5.7C34.2 6.1 29.4 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.7-.4-3.5z"/>
          <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16.1 19 12 24 12c3 0 5.8 1.1 7.9 3l5.7-5.7C34.2 6.1 29.4 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/>
          <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2C29.2 35.3 26.7 36 24 36c-5.3 0-9.7-3.3-11.3-8l-6.5 5C9.6 39.6 16.2 44 24 44z"/>
          <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-1.1 3.2-3.5 5.8-6.5 7.3l.1.1 6.2 5.2C37.2 38.5 44 33 44 24c0-1.3-.1-2.7-.4-3.5z"/>
        </svg>
        Đăng nhập với Google
      </a>
      {{/if}}

      {{#if passwordEnabled}}
      {{#if googleEnabled}}
      <div class="relative py-1 text-center text-xs uppercase tracking-wide text-slate-400">
        <span class="relative z-10 bg-white px-2">hoặc mật khẩu</span>
        <span class="absolute left-0 right-0 top-1/2 z-0 border-t border-slate-100"></span>
      </div>
      {{/if}}

      <form method="POST" action="/dashboard/login" class="space-y-4">
        <input type="hidden" name="next" value="{{next}}" />

        <div>
          <label class="mb-1 block text-sm font-medium text-slate-700">Email</label>
          <input
            name="email"
            type="email"
            required
            autofocus
            value="{{defaultEmail}}"
            class="dash-input w-full"
            autocomplete="username"
          />
        </div>

        <div>
          <label class="mb-1 block text-sm font-medium text-slate-700">Mật khẩu</label>
          <input
            name="password"
            type="password"
            required
            class="dash-input w-full"
            autocomplete="current-password"
          />
        </div>

        <button type="submit" class="dash-btn-primary w-full justify-center">Đăng nhập</button>
      </form>
      {{else}}
        {{#unless googleEnabled}}
        <p class="rounded-lg bg-amber-50 px-3 py-2 text-sm text-amber-800">
          Chưa cấu hình đăng nhập. Thêm <code class="text-xs">GOOGLE_CLIENT_ID</code>,
          <code class="text-xs">GOOGLE_CLIENT_SECRET</code>, <code class="text-xs">ADMIN_EMAIL</code>
          vào môi trường.
        </p>
        {{/unless}}
      {{/if}}

      <a href="/" class="block text-center text-sm text-slate-500 hover:text-brand-600">← Về trang chủ</a>
    </div>
  </div>
  {{/if}}
  {{> live-reload }}
</body>
</html>

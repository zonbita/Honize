<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{pageTitle}} — NewsHub CMS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css{{#if devMode}}?v={{devRevision}}{{/if}}" />
  {{#if alreadyLoggedIn}}
  <meta http-equiv="refresh" content="0;url={{redirectTo}}" />
  {{/if}}
</head>
<body class="min-h-screen bg-[#f0f2f5] font-sans text-slate-700 antialiased">
  {{#if alreadyLoggedIn}}
  <p class="p-8 text-center text-sm text-slate-500">Đang chuyển hướng...</p>
  {{else}}
  <div class="flex min-h-screen items-center justify-center p-6">
    <form method="POST" action="/dashboard/login" class="w-full max-w-md space-y-5 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">NewsHub CMS</p>
        <h1 class="mt-1 text-2xl font-bold text-slate-800">Đăng nhập</h1>
        <p class="mt-1 text-sm text-slate-500">Vào quản trị để chỉnh nội dung website.</p>
      </div>

      {{#if error}}
      <div class="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-600">{{error}}</div>
      {{/if}}

      <input type="hidden" name="next" value="{{next}}" />

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700">Email</label>
        <input
          name="email"
          type="email"
          required
          autofocus
          value="{{defaultEmail}}"
          class="dash-input w-full"
          autocomplete="username"
        />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700">Mật khẩu</label>
        <input
          name="password"
          type="password"
          required
          class="dash-input w-full"
          autocomplete="current-password"
        />
      </div>

      {{#if showDefaultHint}}
      <p class="rounded-lg bg-slate-50 px-3 py-2 text-xs text-slate-500">
        Mặc định (dev): <code class="rounded bg-white px-1">admin@honize.vn</code> /
        <code class="rounded bg-white px-1">Admin@123</code>
      </p>
      {{/if}}

      <button type="submit" class="dash-btn-primary w-full justify-center">Đăng nhập</button>
      <a href="/" class="block text-center text-sm text-slate-500 hover:text-brand-600">← Về trang chủ</a>
    </form>
  </div>
  {{/if}}
  {{> live-reload }}
</body>
</html>

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{pageTitle}}</title>
  {{#if seo}}
  <meta name="description" content="{{seo.description}}" />
  <link rel="canonical" href="{{seo.canonical}}" />
  {{/if}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Great+Vibes&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css{{#if devMode}}?v={{devRevision}}{{/if}}" />
  <link rel="stylesheet" href="/vendor/aos/aos.css{{#if devMode}}?v={{devRevision}}{{/if}}" />
  {{#if demoCss}}
  <link rel="stylesheet" href="{{demoCss}}{{#if devMode}}?v={{devRevision}}{{/if}}" />
  {{/if}}
</head>
<body class="demo-body">
  {{{body}}}
  <script src="/vendor/aos/aos.js{{#if devMode}}?v={{devRevision}}{{/if}}" defer></script>
  <script src="/js/aos-init.js{{#if devMode}}?v={{devRevision}}{{/if}}" defer></script>
  {{#if devMode}}
  {{> live-reload }}
  {{/if}}
</body>
</html>
